{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://siq.local/schemas/research_pack.schema.json",
  "schema_version": 1,
  "title": "SIQ research pack schema",
  "description": "Unified intermediate contract for siq_analysis internal subagents. Packs are written under data/wiki/companies/<company>/analysis/.work/<report_slug>/research_packs/.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "agent_id",
    "company_id",
    "report_year",
    "generated_at",
    "input_files",
    "coverage",
    "key_findings",
    "evidence_facts",
    "calculations",
    "risk_chains",
    "tracking_signals",
    "external_sources",
    "missing_inputs",
    "review_required",
    "prohibited_content_hits"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "Research pack contract version."
    },
    "agent_id": {
      "type": "string",
      "enum": [
        "evidence_curator",
        "financial_modeler",
        "business_strategy_researcher",
        "industry_peer_researcher",
        "governance_risk_researcher",
        "editor_in_chief"
      ]
    },
    "company_id": {
      "type": "string",
      "minLength": 1
    },
    "report_year": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1900,
          "maximum": 2100
        },
        {
          "type": "string",
          "pattern": "^[0-9]{4}$"
        }
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "input_files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input_file"
      },
      "description": "Files read or intentionally skipped while producing this pack."
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_ids",
        "time_periods",
        "source_scope",
        "known_limits"
      ],
      "properties": {
        "section_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Target report sections supported by this pack."
        },
        "time_periods": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_scope": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Evidence classes covered, for example annual_report, metrics, semantic, external_search."
        },
        "known_limits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "key_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/key_finding"
      }
    },
    "evidence_facts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_fact"
      }
    },
    "calculations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/calculation"
      }
    },
    "risk_chains": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk_chain"
      }
    },
    "tracking_signals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tracking_signal"
      }
    },
    "external_sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/external_source"
      },
      "description": "Required for industry_peer_researcher unless missing_inputs explains why unavailable."
    },
    "missing_inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/missing_input"
      }
    },
    "review_required": {
      "type": "boolean"
    },
    "prohibited_content_hits": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/prohibited_content_hit"
      },
      "description": "Must be empty for final use. Non-empty means the pack needs repair or human review."
    }
  },
  "$defs": {
    "fact_status": {
      "type": "string",
      "enum": [
        "verified_fact",
        "modeled_estimate",
        "external_context",
        "assumption",
        "gap"
      ],
      "description": "Truth status for claims and derived items. verified_fact requires resolvable evidence; assumption/gap/external_context must stay out of factual assertions."
    },
    "input_file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "status"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "read",
            "missing",
            "skipped",
            "partial",
            "parse_failed"
          ]
        },
        "purpose": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_file"
      ],
      "properties": {
        "evidence_id": {
          "type": "string"
        },
        "source_file": {
          "type": "string"
        },
        "pdf_page": {
          "type": [
            "integer",
            "string",
            "null"
          ]
        },
        "table_index": {
          "type": [
            "integer",
            "string",
            "null"
          ]
        },
        "md_line": {
          "type": [
            "integer",
            "string",
            "null"
          ]
        },
        "quote": {
          "type": "string"
        }
      }
    },
    "key_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_ids",
        "claim",
        "confidence"
      ],
      "properties": {
        "section_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "fact_status": {
          "$ref": "#/$defs/fact_status"
        },
        "review_required": {
          "type": "boolean"
        },
        "rationale": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_ref"
          }
        }
      }
    },
    "evidence_fact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fact",
        "evidence_refs"
      ],
      "properties": {
        "fact": {
          "type": "string",
          "minLength": 1
        },
        "period": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "fact_status": {
          "$ref": "#/$defs/fact_status"
        },
        "review_required": {
          "type": "boolean"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_ref"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "calculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "formula",
        "inputs",
        "output",
        "evidence_refs"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "formula": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": [
            "object",
            "array"
          ]
        },
        "output": {
          "type": [
            "object",
            "array",
            "number",
            "string",
            "boolean",
            "null"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_ref"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "fact_status": {
          "$ref": "#/$defs/fact_status"
        },
        "review_required": {
          "type": "boolean"
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "review_note": {
          "type": "string"
        }
      }
    },
    "risk_chain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chain",
        "evidence_refs"
      ],
      "properties": {
        "section_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "chain": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 2
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "unknown"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "fact_status": {
          "$ref": "#/$defs/fact_status"
        },
        "review_required": {
          "type": "boolean"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_ref"
          }
        },
        "counter_signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "tracking_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal",
        "why_it_matters"
      ],
      "properties": {
        "signal": {
          "type": "string"
        },
        "why_it_matters": {
          "type": "string"
        },
        "direction": {
          "type": "string",
          "enum": [
            "improve",
            "deteriorate",
            "confirm",
            "falsify",
            "unknown"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "fact_status": {
          "$ref": "#/$defs/fact_status"
        },
        "review_required": {
          "type": "boolean"
        },
        "source_hint": {
          "type": "string"
        },
        "section_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "external_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "query",
        "url",
        "title"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "query": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        },
        "summary": {
          "type": "string"
        },
        "reliability": {
          "type": "string",
          "enum": [
            "primary",
            "official",
            "reputable_media",
            "data_vendor",
            "unknown"
          ]
        }
      }
    },
    "missing_input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "reason",
        "impact"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "impact": {
          "type": "string"
        },
        "requested_action": {
          "type": "string"
        },
        "section_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "prohibited_content_hit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "content_type",
        "location",
        "text"
      ],
      "properties": {
        "content_type": {
          "type": "string",
          "enum": [
            "target_price",
            "rating",
            "trade_instruction",
            "unsupported_fact",
            "legal_conclusion",
            "other"
          ]
        },
        "location": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "warning",
            "failure"
          ]
        }
      }
    }
  }
}
