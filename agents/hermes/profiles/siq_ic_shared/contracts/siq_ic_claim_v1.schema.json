{
  "$id": "siq_ic_claim_v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "assumption": {
      "maxLength": 4000,
      "type": [
        "string",
        "null"
      ]
    },
    "background_knowledge_ref_ids": {
      "items": {
        "pattern": "^KBREF-[A-Z0-9][A-Z0-9-]{5,95}$",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "calculation_trace_ids": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "claim_id": {
      "pattern": "^CLM-[A-Z0-9][A-Z0-9-]{5,95}$",
      "type": "string"
    },
    "conclusion": {
      "maxLength": 8000,
      "minLength": 1,
      "type": "string"
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low"
      ],
      "type": "string"
    },
    "counter_evidence_ids": {
      "items": {
        "pattern": "^EVID-[A-Za-z0-9][A-Za-z0-9:_-]{2,190}$",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "currency": {
      "maxLength": 16,
      "type": [
        "string",
        "null"
      ]
    },
    "decision_impact": {
      "enum": [
        "critical",
        "material",
        "supporting"
      ],
      "type": "string"
    },
    "evidence_ids": {
      "items": {
        "pattern": "^EVID-[A-Za-z0-9][A-Za-z0-9:_-]{2,190}$",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "methodology_ref_ids": {
      "items": {
        "pattern": "^KBREF-[A-Z0-9][A-Z0-9-]{5,95}$",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "period": {
      "maxLength": 80,
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "enum": [
        "verified",
        "derived",
        "assumed",
        "contested",
        "missing"
      ],
      "type": "string"
    },
    "topic": {
      "maxLength": 120,
      "minLength": 1,
      "type": "string"
    },
    "unit": {
      "maxLength": 32,
      "type": [
        "string",
        "null"
      ]
    },
    "value": {
      "type": [
        "number",
        "string",
        "null"
      ]
    },
    "verification_method": {
      "maxLength": 4000,
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "claim_id",
    "topic",
    "conclusion",
    "status",
    "evidence_ids",
    "counter_evidence_ids",
    "calculation_trace_ids",
    "background_knowledge_ref_ids",
    "methodology_ref_ids",
    "confidence",
    "decision_impact",
    "period",
    "currency",
    "unit"
  ],
  "type": "object"
}
