{
  "$id": "siq_ic_workflow_run_v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "active_sources": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "completed_at": {
      "format": "date-time",
      "type": "string"
    },
    "completion": {
      "type": "object"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "created_by": {
      "type": [
        "object",
        "null"
      ]
    },
    "deal_id": {
      "pattern": "^[A-Z0-9][A-Z0-9_-]{2,96}$",
      "type": "string"
    },
    "evidence_snapshot_hash": {
      "anyOf": [
        {
          "pattern": "^[a-fA-F0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "schema_version": {
      "const": "siq_ic_workflow_run_v1"
    },
    "source_ids": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "status": {
      "enum": [
        "active",
        "superseded_by_snapshot",
        "completed",
        "cancelled"
      ]
    },
    "updated_at": {
      "format": "date-time",
      "type": "string"
    },
    "workflow_run_id": {
      "pattern": "^ICRUN-[A-Z0-9][A-Z0-9-]{7,95}$",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "workflow_run_id",
    "deal_id",
    "status",
    "evidence_snapshot_hash",
    "source_ids",
    "active_sources",
    "created_at",
    "updated_at"
  ],
  "type": "object"
}
