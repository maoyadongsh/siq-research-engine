{
  "schema_version": "siq_ic_openclaw_behavior_migration_matrix_v2",
  "updated_at": "2026-07-13",
  "purpose": "Track evidence-backed behavioral parity from OpenClaw IC workspaces into SIQ Hermes profiles without treating copied assets, deterministic fallbacks, or API contracts as proof of model behavior or report quality.",
  "authority": {
    "direction": "openclaw_reference_to_hermes_only",
    "production_authority": "agents/hermes/profiles/siq_ic_*",
    "forbidden_sync": [
      "workspace runtime state",
      "memory and chat history",
      "credentials and local configuration",
      "cache and virtualenv files",
      "project conclusions without SIQ Evidence rebinding"
    ]
  },
  "source_scope": [
    "ic_master_coordinator_workspace",
    "ic_chairman_workspace",
    "ic_strategist_workspace",
    "ic_sector_expert_workspace",
    "ic_finance_auditor_workspace",
    "ic_legal_scanner_workspace",
    "ic_risk_controller_workspace"
  ],
  "parity_definitions": {
    "asset_migrated": "Stable role, method, template, or policy assets exist in Hermes. This does not prove an executable contract or runtime behavior.",
    "contract_migrated": "Versioned input/output contracts, task templates, validators, or API boundaries exist. This does not prove the intended model interaction occurred.",
    "behavior_migrated": "The SIQ-native runtime executes the intended behavior with durable handoffs and automated behavioral tests. Deterministic fallback behavior is identified separately.",
    "quality_accepted": "Golden cases and release metrics passed human methodology review. No behavior reaches this level only because code or a sample report exists."
  },
  "acceptance_policy": {
    "quality_accepted_requires": [
      "golden case evidence rebinding",
      "role-boundary evaluation",
      "claim and citation accuracy evaluation",
      "cross-agent handoff evaluation",
      "full-report completeness and factcheck",
      "recorded human methodology approval"
    ],
    "deterministic_fallback_is_model_parity": false,
    "copied_asset_is_behavior_parity": false,
    "quality_accepted_default": false
  },
