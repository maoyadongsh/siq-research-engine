{
  "schema_version": 2,
  "contract_version": "siq_ic_profile_matrix_v2",
  "group": "ic",
  "shared_collection": {
    "logical": "siq_deal_shared",
    "physical": "ic_collaboration_shared",
    "source_class": "project_evidence",
    "rule": "Project facts and formal claims must cite Deal-scoped Evidence from the shared collection."
  },
  "private_collection_rule": {
    "required": true,
    "source_class": "background_knowledge",
    "rule": "Every profile must retrieve its own private background collection. Background knowledge may provide methods, comparables, and challenge hypotheses, but cannot prove a project fact without project Evidence."
  },
  "namespace_policy": {
    "namespace": "primary_market",
    "allowed_roots": ["data/wiki/deals/{deal_id}"],
    "forbidden_roots": ["data/wiki/companies"],
    "rule": "Primary-market IC profiles may use only deal-scoped project packages. They must not read secondary-market company Wiki data under data/wiki/companies."
  },
  "profiles": [
    {
      "id": "siq_ic_master_coordinator",
      "role": "master_coordinator",
      "label": "投委会总协调",
      "port": 18660,
      "source_workspace": "ic_master_coordinator_workspace",
      "responsibilities": [
        "verify project identity, material scope, evidence snapshot, and workflow gates",
        "orchestrate durable R0-R4 handoffs without replacing expert judgment",
        "track evidence gaps, stale outputs, quality findings, and human confirmation",
        "assemble accepted artifacts and audit identity"
      ],
      "boundaries": [
        "does not write expert conclusions",
        "does not convert background knowledge into project facts",
        "does not silently accept deterministic fallback as model output"
      ],
      "independent_services": [
        "ic_phase_orchestrator",
        "ic_startup_retrieval",
        "deal_evidence",
        "deal_discussion"
      ],
      "skill_ids": [
        "due-diligence-dataroom",
        "deal-tracker",
        "dd-checklist",
        "ic-memo"
      ],
      "phase_capabilities": {
        "R0": ["readiness", "scope", "evidence_gap_plan"],
        "R1A": ["dispatch", "lease_and_handoff_tracking"],
        "R1B": ["handoff_tracking"],
        "R1.5": ["followup_task_tracking"],
        "R2": ["revision_tracking"],
        "R3": ["debate_orchestration"],
        "R4": ["report_assembly", "quality_gate", "human_confirmation_gate"]
      },
      "output_schemas": {
        "R0": "contracts/siq_ic_r0_readiness_v1.schema.json",
        "handoff": "contracts/siq_ic_agent_handoff_v2.schema.json"
      },
      "retrieval": {
        "required": true,
        "logical_collections": ["siq_deal_shared", "siq_ic_master_coordinator"],
        "physical_collections": ["ic_collaboration_shared", "ic_master_coordinator"],
        "private_collection": "ic_master_coordinator"
      }
    },
    {
      "id": "siq_ic_chairman",
      "role": "chairman",
      "label": "投委会主席",
      "port": 18661,
      "source_workspace": "ic_chairman_workspace",
      "responsibilities": [
        "synthesize R1A expert reports without erasing disagreement",
        "rule R1.5 disputes and issue evidence followups",
        "deliver R3 verdicts against explicit arguments and Evidence",
        "produce R4 six-dimension decision, conditions, and score-change rationale"
      ],
      "boundaries": [
        "does not replace specialist analysis",
        "does not use weighted average as the sole decision",
        "does not pass unresolved high or critical disputes"
      ],
      "independent_services": [
        "ic_phase_orchestrator",
        "ic_scoring",
        "deal_disputes",
        "ic_report_quality"
      ],
      "skill_ids": [
        "deal-screening",
        "ic-memo",
        "term-sheet-analyzer",
        "value-creation-plan",
        "returns-analysis"
      ],
      "phase_capabilities": {
        "R1B": ["initial_synthesis", "dispute_candidates"],
        "R1.5": ["chairman_ruling", "evidence_followup"],
        "R3": ["debate_verdict"],
        "R4": ["structured_decision", "six_dimension_scoring", "conditions"]
      },
      "output_schemas": {
        "R1B": "contracts/siq_ic_expert_report_v2.schema.json",
        "R1.5": "contracts/siq_ic_r1_5_dispute_v1.schema.json",
        "R3": "contracts/siq_ic_r3_debate_v1.schema.json",
        "R4": "contracts/siq_ic_r4_decision_v2.schema.json"
      },
      "retrieval": {
        "required": true,
        "logical_collections": ["siq_deal_shared", "siq_ic_chairman"],
        "physical_collections": ["ic_collaboration_shared", "ic_chairman"],
        "private_collection": "ic_chairman"
      }
    },
    {
      "id": "siq_ic_strategist",
      "role": "strategy",
      "label": "战略委员",
      "port": 18662,
      "source_workspace": "ic_strategist_workspace",
      "responsibilities": [
        "analyze policy, macro cycle, capital flows, strategic fit, and exit window",
        "state falsifiable strategic assumptions and downside triggers",
        "revise conclusions in R2 against rulings and new Evidence"
      ],
      "boundaries": [
        "does not perform legal opinion or detailed financial audit",
        "does not claim company-specific facts from macro background knowledge"
      ],
      "independent_services": [
        "deal_retrieval",
        "external_research_clients",
        "ic_phase_orchestrator"
      ],
      "skill_ids": [
        "company-investment-research",
        "thesis-tracker",
        "portfolio-monitoring",
        "value-creation-plan",
        "venture-capital"
      ],
      "phase_capabilities": {
        "R1A": ["independent_strategy_report"],
        "R2": ["strategy_revision", "score_delta"],
        "R3": ["red_or_blue_argument_on_strategy_topics"]
      },
      "output_schemas": {
        "R1": "contracts/siq_ic_expert_report_v2.schema.json",
        "R2": "contracts/siq_ic_r2_revision_v1.schema.json",
        "R3": "contracts/siq_ic_r3_debate_v1.schema.json"
      },
      "retrieval": {
        "required": true,
        "logical_collections": ["siq_deal_shared", "siq_ic_strategist"],
        "physical_collections": ["ic_collaboration_shared", "ic_strategist"],
        "private_collection": "ic_strategist"
      }
    },
    {
      "id": "siq_ic_sector_expert",
      "role": "sector",
      "label": "行业专家",
      "port": 18663,
      "source_workspace": "ic_sector_expert_workspace",
      "responsibilities": [
        "analyze TAM/SAM/SOM, competition, technology route, industry chain, customers, and suppliers",
        "separate market facts from industry-method background knowledge",
        "revise market and moat conclusions in R2"
      ],
      "boundaries": [
        "does not certify financial statements or legal compliance",
        "does not treat generic industry benchmarks as issuer facts"
      ],
      "independent_services": [
        "deal_retrieval",
        "external_research_clients",
        "primary_market_materials",
        "ic_phase_orchestrator"
      ],
      "skill_ids": [
        "sector-overview",
        "competitive-analysis",
        "strategic-competitor-analysis",
        "tam-sam-som",
        "market-intelligence-claw"
      ],
      "phase_capabilities": {
        "R1A": ["independent_sector_report"],
        "R2": ["sector_revision", "score_delta"],
        "R3": ["red_or_blue_argument_on_market_and_technology_topics"]
      },
      "output_schemas": {
        "R1": "contracts/siq_ic_expert_report_v2.schema.json",
        "R2": "contracts/siq_ic_r2_revision_v1.schema.json",
        "R3": "contracts/siq_ic_r3_debate_v1.schema.json"
      },
      "retrieval": {
        "required": true,
        "logical_collections": ["siq_deal_shared", "siq_ic_sector_expert"],
        "physical_collections": ["ic_collaboration_shared", "ic_sector_expert"],
        "private_collection": "ic_sector_expert"
      }
    },
    {
      "id": "siq_ic_finance_auditor",
      "role": "finance",
      "label": "财务审计委员",
      "port": 18664,
      "source_workspace": "ic_finance_auditor_workspace",
      "responsibilities": [
        "verify historical financials, revenue quality, statement reconciliation, forecasts, valuation, and sensitivities",
        "preserve period, currency, unit, formula, and calculator trace",
        "mark numbers insufficient when financial Evidence capability is restricted"
      ],
      "boundaries": [
        "does not invent missing periods or normalize units without trace",
        "does not mark background benchmarks as verified issuer numbers"
      ],
      "independent_services": [
        "deal_evidence",
        "deal_retrieval",
        "agent_runtime_financial_claim_verifier",
        "agent_runtime_financial_trace",
        "ic_phase_orchestrator"
      ],
      "skill_ids": [
        "ic-finance-auditor",
        "3-statement-model",
        "financial-analysis-agent",
        "dcf-model",
        "comps-analysis",
        "unit-economics",
        "returns-analysis"
      ],
      "phase_capabilities": {
        "R1A": ["independent_finance_report", "numeric_trace"],
        "R2": ["finance_revision", "score_delta", "model_recalculation"],
        "R3": ["red_or_blue_argument_on_finance_and_valuation_topics"]
      },
      "output_schemas": {
        "R1": "contracts/siq_ic_expert_report_v2.schema.json",
        "R2": "contracts/siq_ic_r2_revision_v1.schema.json",
        "R3": "contracts/siq_ic_r3_debate_v1.schema.json"
      },
      "retrieval": {
        "required": true,
        "logical_collections": ["siq_deal_shared", "siq_ic_finance_auditor"],
        "physical_collections": ["ic_collaboration_shared", "ic_finance_auditor"],
        "private_collection": "ic_finance_auditor"
      }
    },
    {
      "id": "siq_ic_legal_scanner",
      "role": "legal",
      "label": "法务扫描委员",
      "port": 18665,
      "source_workspace": "ic_legal_scanner_workspace",
      "responsibilities": [
        "analyze ownership, licenses, litigation, IP, related transactions, data compliance, and closing conditions",
        "link each legal conclusion to authority and project Evidence",
        "design remediation and transaction conditions"
      ],
      "boundaries": [
        "does not infer legal status from generic regulation summaries",
        "does not replace industry or financial analysis"
      ],
      "independent_services": [
        "deal_evidence",
        "deal_retrieval",
        "external_research_clients",
        "ic_phase_orchestrator"
      ],
      "skill_ids": [
        "term-sheet-analyzer",
        "dd-checklist",
        "due-diligence-analyst",
        "due-diligence-dataroom"
      ],
      "phase_capabilities": {
        "R1A": ["independent_legal_report"],
        "R2": ["legal_revision", "score_delta", "condition_update"],
        "R3": ["red_or_blue_argument_on_legal_and_compliance_topics"]
      },
      "output_schemas": {
        "R1": "contracts/siq_ic_expert_report_v2.schema.json",
        "R2": "contracts/siq_ic_r2_revision_v1.schema.json",
        "R3": "contracts/siq_ic_r3_debate_v1.schema.json"
      },
      "retrieval": {
        "required": true,
        "logical_collections": ["siq_deal_shared", "siq_ic_legal_scanner"],
        "physical_collections": ["ic_collaboration_shared", "ic_legal_scanner"],
        "private_collection": "ic_legal_scanner"
      }
    },
    {
      "id": "siq_ic_risk_controller",
      "role": "risk",
      "label": "风控委员",
      "port": 18666,
      "source_workspace": "ic_risk_controller_workspace",
      "responsibilities": [
        "read all independent reports and construct counter-evidence, stress scenarios, transmission paths, indicators, and stop-loss thresholds",
        "identify veto items and challenge correlated assumptions",
        "revise risk position after chairman rulings and new Evidence"
      ],
      "boundaries": [
        "does not repeat specialist reports without stress testing",
        "does not substitute generic risk cases for issuer Evidence"
      ],
      "independent_services": [
        "deal_retrieval",
        "external_research_clients",
        "ic_report_quality",
        "ic_phase_orchestrator"
      ],
      "skill_ids": [
        "risk-metrics-calculation",
        "due-diligence-analyst",
        "dd-checklist",
        "return-rate-impact-calculator",
        "portfolio-monitoring"
      ],
      "phase_capabilities": {
        "R1B": ["cross_report_stress_test", "counter_evidence", "veto_scan"],
        "R2": ["risk_revision", "score_delta", "threshold_update"],
        "R3": ["red_team_lead", "rebuttal"]
      },
      "output_schemas": {
        "R1": "contracts/siq_ic_expert_report_v2.schema.json",
        "R2": "contracts/siq_ic_r2_revision_v1.schema.json",
        "R3": "contracts/siq_ic_r3_debate_v1.schema.json"
      },
      "retrieval": {
        "required": true,
        "logical_collections": ["siq_deal_shared", "siq_ic_risk_controller"],
        "physical_collections": ["ic_collaboration_shared", "ic_risk_controller"],
        "private_collection": "ic_risk_controller"
      }
    }
  ]
}
