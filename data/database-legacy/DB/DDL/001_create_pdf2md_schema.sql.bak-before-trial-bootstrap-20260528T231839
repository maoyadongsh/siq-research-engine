CREATE INDEX IF NOT EXISTS idx_eval_results_metric ON pdf2md.evaluation_results(metric_name);
CREATE INDEX IF NOT EXISTS idx_fin_items_company_ext ON pdf2md.financial_statement_items(company_id, report_year, canonical_name, period_key);
CREATE INDEX IF NOT EXISTS idx_fin_metrics_company_ext ON pdf2md.financial_key_metrics(company_id, canonical_name, period_key);

