-- PostgreSQL schema for pdf2md document_full.json persistence.
-- Stores queryable metadata, structure indexes, financial facts, and artifact references.
-- Large raw files such as PDF/images/Markdown remain on disk or object storage.

CREATE SCHEMA IF NOT EXISTS pdf2md;

CREATE TABLE IF NOT EXISTS pdf2md.documents (
    task_id TEXT PRIMARY KEY,
    mineru_task_id TEXT,
    filename TEXT NOT NULL,
    status TEXT,
    stage TEXT,
    created_at TIMESTAMPTZ,
    completed_at TIMESTAMPTZ,
    generated_at TIMESTAMPTZ,
    pdf_page_count INTEGER,
    schema_version INTEGER,
    report_kind TEXT,
    report_year INTEGER,
    submit_config JSONB NOT NULL DEFAULT '{}'::jsonb,
    source_files JSONB NOT NULL DEFAULT '{}'::jsonb,
    result_dir TEXT,
    document_full_path TEXT,
    markdown_path TEXT,
    complete_markdown_path TEXT,
    markdown_chars INTEGER,
    markdown_line_count INTEGER,
    financial_overall_status TEXT,
    quality_summary JSONB NOT NULL DEFAULT '{}'::jsonb,
    financial_summary JSONB NOT NULL DEFAULT '{}'::jsonb,
    resources_summary JSONB NOT NULL DEFAULT '{}'::jsonb,
    raw_task JSONB NOT NULL DEFAULT '{}'::jsonb,
    raw_json_hash TEXT,
    raw_json_size_bytes BIGINT,
    imported_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    updated_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

COMMENT ON TABLE pdf2md.documents IS '文档/任务主表。来源 document_full.json.task、markdown、quality_report、financial_data、financial_checks、resources、artifacts。';
COMMENT ON COLUMN pdf2md.documents.task_id IS '任务 ID，来源 task.task_id；如果缺失则使用 document_full.json 所在目录名。';
COMMENT ON COLUMN pdf2md.documents.mineru_task_id IS '上游 MinerU 任务 ID，来源 task.mineru_task_id。';
COMMENT ON COLUMN pdf2md.documents.filename IS '原始 PDF 文件名，来源 task.filename。';
COMMENT ON COLUMN pdf2md.documents.status IS '任务状态，来源 task.status。';
COMMENT ON COLUMN pdf2md.documents.stage IS '任务阶段，来源 task.stage。';
COMMENT ON COLUMN pdf2md.documents.created_at IS '任务创建时间，来源 task.created_at。';
COMMENT ON COLUMN pdf2md.documents.completed_at IS '任务完成时间，来源 task.completed_at。';
COMMENT ON COLUMN pdf2md.documents.generated_at IS 'document_full.json 生成时间，来源 generated_at。';
COMMENT ON COLUMN pdf2md.documents.pdf_page_count IS 'PDF 页数，优先来源 task.pdf_page_count，其次 quality_report.pdf_page_count。';
COMMENT ON COLUMN pdf2md.documents.schema_version IS 'document_full.json schema 版本，来源 schema_version。';
COMMENT ON COLUMN pdf2md.documents.report_kind IS '报告类型，来源 quality_report.report_kind 或 financial_data.report_kind。';
COMMENT ON COLUMN pdf2md.documents.report_year IS '报告年份，来源 quality_report.report_year 或 financial_data.report_year。';
COMMENT ON COLUMN pdf2md.documents.submit_config IS '解析提交配置，来源 task.submit_config。';
COMMENT ON COLUMN pdf2md.documents.source_files IS '原始 PDF、result.md、result_complete.md 等源文件引用，来源 source_files。';
COMMENT ON COLUMN pdf2md.documents.result_dir IS '任务结果目录，由 document_full.json 路径推导。';
COMMENT ON COLUMN pdf2md.documents.document_full_path IS 'document_full.json 本地路径，来源 artifacts.document_full.json.path 或导入路径。';
COMMENT ON COLUMN pdf2md.documents.markdown_path IS 'result.md 本地路径，来源 source_files.markdown.path。';
COMMENT ON COLUMN pdf2md.documents.complete_markdown_path IS 'result_complete.md 本地路径，来源 source_files.complete_markdown.path。';
COMMENT ON COLUMN pdf2md.documents.markdown_chars IS 'Markdown 字符数，来源 markdown.chars。';
COMMENT ON COLUMN pdf2md.documents.markdown_line_count IS 'Markdown 行数，来源 markdown.line_count。';
COMMENT ON COLUMN pdf2md.documents.financial_overall_status IS '财务勾稽整体状态，来源 financial_checks.overall_status 或 quality_report.financial_overall_status。';
COMMENT ON COLUMN pdf2md.documents.quality_summary IS '质量摘要 JSON，抽取自 quality_report 的统计字段和 warnings。';
COMMENT ON COLUMN pdf2md.documents.financial_summary IS '财务数据/勾稽摘要，来源 financial_checks.summary 或 financial_data.summary。';
COMMENT ON COLUMN pdf2md.documents.resources_summary IS '图片和 PDF 页图资源数量/大小摘要，来源 resources.images.summary、resources.pdf_pages.summary。';
COMMENT ON COLUMN pdf2md.documents.raw_task IS 'task 原始 JSON 备份。';
COMMENT ON COLUMN pdf2md.documents.raw_json_hash IS '导入的 document_full.json 文件 SHA256。';
COMMENT ON COLUMN pdf2md.documents.raw_json_size_bytes IS '导入的 document_full.json 文件大小。';

CREATE TABLE IF NOT EXISTS pdf2md.document_artifacts (
    task_id TEXT NOT NULL REFERENCES pdf2md.documents(task_id) ON DELETE CASCADE,
    artifact_name TEXT NOT NULL,
    kind TEXT,
    path TEXT,
    url TEXT,
    exists BOOLEAN,
    size_bytes BIGINT,
    mtime TIMESTAMPTZ,
    sha256 TEXT,
    raw JSONB NOT NULL DEFAULT '{}'::jsonb,
    imported_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    PRIMARY KEY (task_id, artifact_name)
);

COMMENT ON TABLE pdf2md.document_artifacts IS '任务产物引用表。来源 document_full.json.artifacts 与 source_files，只存路径、URL、大小、mtime、原始引用 JSON，不存大文件内容。';
COMMENT ON COLUMN pdf2md.document_artifacts.task_id IS '关联 documents.task_id，表示该产物属于哪个解析任务。';
COMMENT ON COLUMN pdf2md.document_artifacts.artifact_name IS '产物名称，如 result.md、document_full.json、content_list.json、images、source:markdown。';
COMMENT ON COLUMN pdf2md.document_artifacts.kind IS '产物类型，如 markdown、pdf、directory。';
COMMENT ON COLUMN pdf2md.document_artifacts.path IS '本地文件或目录路径。';
COMMENT ON COLUMN pdf2md.document_artifacts.url IS 'Web 可打开 URL。';
COMMENT ON COLUMN pdf2md.document_artifacts.exists IS '导出时文件是否存在。';
COMMENT ON COLUMN pdf2md.document_artifacts.size_bytes IS '产物文件大小，单位字节，来源 artifact/source_files 的 size_bytes。';
COMMENT ON COLUMN pdf2md.document_artifacts.mtime IS '产物文件修改时间，来源 artifact/source_files 的 mtime。';
COMMENT ON COLUMN pdf2md.document_artifacts.sha256 IS '产物文件 SHA256，预留字段，用于文件完整性校验。';
COMMENT ON COLUMN pdf2md.document_artifacts.raw IS 'artifact/source_files 对应条目的原始 JSON。';
COMMENT ON COLUMN pdf2md.document_artifacts.imported_at IS '该产物引用写入数据库的时间。';

CREATE TABLE IF NOT EXISTS pdf2md.document_pages (
    task_id TEXT NOT NULL REFERENCES pdf2md.documents(task_id) ON DELETE CASCADE,
    page_number INTEGER NOT NULL,
    page_index INTEGER,
    markdown_start INTEGER,
    markdown_end INTEGER,
    block_count INTEGER,
    preview TEXT,
    raw JSONB NOT NULL DEFAULT '{}'::jsonb,
    imported_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    PRIMARY KEY (task_id, page_number)
);

COMMENT ON TABLE pdf2md.document_pages IS '页级索引表。来源 markdown.pages 与 content_list_enhanced.pages，用于页级检索、RAG 分片和 PDF 页跳转。';
COMMENT ON COLUMN pdf2md.document_pages.task_id IS '关联 documents.task_id，表示页面所属解析任务。';
COMMENT ON COLUMN pdf2md.document_pages.page_number IS 'PDF 页码，通常从 1 开始。';
COMMENT ON COLUMN pdf2md.document_pages.page_index IS 'PDF 页索引，通常从 0 开始。';
COMMENT ON COLUMN pdf2md.document_pages.markdown_start IS '该页在 Markdown 正文中的起始偏移，如果来源提供。';
COMMENT ON COLUMN pdf2md.document_pages.markdown_end IS '该页在 Markdown 正文中的结束偏移，如果来源提供。';
COMMENT ON COLUMN pdf2md.document_pages.block_count IS '该页内容块数量，来源 content_list_enhanced.pages。';
COMMENT ON COLUMN pdf2md.document_pages.preview IS '页内容预览文本，来自 markdown.pages 或 enhanced pages。';
COMMENT ON COLUMN pdf2md.document_pages.raw IS '页级来源原始 JSON，来自 markdown.pages 和 content_list_enhanced.pages 的合并结果。';
COMMENT ON COLUMN pdf2md.document_pages.imported_at IS '该页索引写入数据库的时间。';

CREATE TABLE IF NOT EXISTS pdf2md.content_blocks (
    task_id TEXT NOT NULL REFERENCES pdf2md.documents(task_id) ON DELETE CASCADE,
    block_index INTEGER NOT NULL,
    block_type TEXT,
    page_idx INTEGER,
    page_number INTEGER,
    bbox JSONB,
    text_preview TEXT,
    image_path TEXT,
    table_html_present BOOLEAN NOT NULL DEFAULT false,
    raw JSONB NOT NULL DEFAULT '{}'::jsonb,
    imported_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    PRIMARY KEY (task_id, block_index)
);

COMMENT ON TABLE pdf2md.content_blocks IS 'MinerU 原始内容块轻量索引。来源 content_list，每个 text/table/image/header/list 等块一行，raw 保留原块 JSON。';
COMMENT ON COLUMN pdf2md.content_blocks.task_id IS '关联 documents.task_id，表示内容块所属解析任务。';
COMMENT ON COLUMN pdf2md.content_blocks.block_index IS '内容块序号，按 content_list 顺序生成。';
COMMENT ON COLUMN pdf2md.content_blocks.block_type IS '块类型，来源 content_list[].type。';
COMMENT ON COLUMN pdf2md.content_blocks.page_idx IS 'PDF 页索引，来源 content_list[].page_idx。';
COMMENT ON COLUMN pdf2md.content_blocks.page_number IS 'PDF 页码，page_idx + 1。';
COMMENT ON COLUMN pdf2md.content_blocks.bbox IS '块在 PDF 页内的坐标，来源 content_list[].bbox。';
COMMENT ON COLUMN pdf2md.content_blocks.text_preview IS '块文本/标题/图片 caption 的短预览。';
COMMENT ON COLUMN pdf2md.content_blocks.image_path IS '图片路径，来源 img_path 或 image_path。';
COMMENT ON COLUMN pdf2md.content_blocks.table_html_present IS '该块是否包含表格 HTML/body。';
COMMENT ON COLUMN pdf2md.content_blocks.raw IS 'content_list 中该内容块的原始 JSON。';
COMMENT ON COLUMN pdf2md.content_blocks.imported_at IS '该内容块写入数据库的时间。';

CREATE TABLE IF NOT EXISTS pdf2md.document_tables (
    task_id TEXT NOT NULL REFERENCES pdf2md.documents(task_id) ON DELETE CASCADE,
    table_index INTEGER NOT NULL,
    markdown_line INTEGER,
    pdf_page_number INTEGER,
    pdf_page_index INTEGER,
    bbox JSONB,
    source TEXT,
    confidence TEXT,
    source_image_path TEXT,
    rows_count INTEGER,
    cells_count INTEGER,
    heading TEXT,
    unit TEXT,
    preview TEXT,
    report_year INTEGER,
    is_multi_level_header_candidate BOOLEAN,
    is_suspicious BOOLEAN NOT NULL DEFAULT false,
    suspect_reasons JSONB NOT NULL DEFAULT '[]'::jsonb,
    source_caption JSONB NOT NULL DEFAULT '[]'::jsonb,
    source_footnote JSONB NOT NULL DEFAULT '[]'::jsonb,
    structure JSONB NOT NULL DEFAULT '{}'::jsonb,
    raw JSONB NOT NULL DEFAULT '{}'::jsonb,
    imported_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    PRIMARY KEY (task_id, table_index)
);

COMMENT ON TABLE pdf2md.document_tables IS '表格溯源和质量索引。来源 content_list_enhanced.tables，并合并 quality_report.table_index/suspicious_tables。';
COMMENT ON COLUMN pdf2md.document_tables.task_id IS '关联 documents.task_id，表示表格所属解析任务。';
COMMENT ON COLUMN pdf2md.document_tables.table_index IS '表格编号，来源 tables[].table_index。';
COMMENT ON COLUMN pdf2md.document_tables.markdown_line IS '表格在 Markdown 中的行号，来源 tables[].line 或 quality_report.table_index[].line。';
COMMENT ON COLUMN pdf2md.document_tables.pdf_page_number IS '表格所在 PDF 页码，来源 content_list_enhanced.tables[].pdf_page_number。';
COMMENT ON COLUMN pdf2md.document_tables.pdf_page_index IS '表格所在 PDF 页索引，通常从 0 开始。';
COMMENT ON COLUMN pdf2md.document_tables.bbox IS '表格在 PDF 页内坐标，来源 content_list_enhanced.tables[].bbox。';
COMMENT ON COLUMN pdf2md.document_tables.source IS '页码/bbox 来源，如 content_list_body_exact、markdown_marker_inferred、unresolved。';
COMMENT ON COLUMN pdf2md.document_tables.confidence IS '表格来源置信度，来源 content_list_enhanced.tables[].confidence。';
COMMENT ON COLUMN pdf2md.document_tables.source_image_path IS '表格来源图片路径，来源 source_image_path。';
COMMENT ON COLUMN pdf2md.document_tables.rows_count IS '表格行数，来源 content_list_enhanced.tables[].rows。';
COMMENT ON COLUMN pdf2md.document_tables.cells_count IS '表格单元格数量，来源 content_list_enhanced.tables[].cells。';
COMMENT ON COLUMN pdf2md.document_tables.heading IS '表格附近标题，来源 quality_report.table_index[].heading。';
COMMENT ON COLUMN pdf2md.document_tables.unit IS '表格单位，来源 quality_report.table_index[].unit。';
COMMENT ON COLUMN pdf2md.document_tables.preview IS '表格文本预览，用于列表展示和快速检索。';
COMMENT ON COLUMN pdf2md.document_tables.report_year IS '报告年份，来源 content_list_enhanced.tables[].report_year 或 quality_report。';
COMMENT ON COLUMN pdf2md.document_tables.is_multi_level_header_candidate IS '是否疑似多级表头，来源 structure.multi_level_header_candidate。';
COMMENT ON COLUMN pdf2md.document_tables.is_suspicious IS '是否被质量报告标记为可疑表，来源 quality_report.suspicious_tables。';
COMMENT ON COLUMN pdf2md.document_tables.suspect_reasons IS '可疑表原因列表，来源 quality_report.suspicious_tables。';
COMMENT ON COLUMN pdf2md.document_tables.source_caption IS '表格 caption，来源 content_list_enhanced.tables[].source_caption。';
COMMENT ON COLUMN pdf2md.document_tables.source_footnote IS '表格脚注，来源 content_list_enhanced.tables[].source_footnote。';
COMMENT ON COLUMN pdf2md.document_tables.structure IS '表格结构信号，如行列数、colspan/rowspan、表头预览。';
COMMENT ON COLUMN pdf2md.document_tables.raw IS '表格增强索引和质量索引合并后的原始 JSON。';
COMMENT ON COLUMN pdf2md.document_tables.imported_at IS '该表格索引写入数据库的时间。';

CREATE TABLE IF NOT EXISTS pdf2md.quality_warnings (
    task_id TEXT NOT NULL REFERENCES pdf2md.documents(task_id) ON DELETE CASCADE,
    warning_index INTEGER NOT NULL,
    warning TEXT NOT NULL,
    imported_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    PRIMARY KEY (task_id, warning_index)
);

COMMENT ON TABLE pdf2md.quality_warnings IS '质量告警明细。来源 quality_report.warnings。';
COMMENT ON COLUMN pdf2md.quality_warnings.task_id IS '关联 documents.task_id，表示质量告警所属解析任务。';
COMMENT ON COLUMN pdf2md.quality_warnings.warning_index IS '质量告警序号，按 quality_report.warnings 顺序生成。';
COMMENT ON COLUMN pdf2md.quality_warnings.warning IS '质量告警文本，来源 quality_report.warnings。';
COMMENT ON COLUMN pdf2md.quality_warnings.imported_at IS '该质量告警写入数据库的时间。';

CREATE TABLE IF NOT EXISTS pdf2md.footnotes (
    task_id TEXT NOT NULL REFERENCES pdf2md.documents(task_id) ON DELETE CASCADE,
    footnote_index INTEGER NOT NULL,
    page_number INTEGER,
    markdown_line INTEGER,
    text TEXT,
    raw JSONB NOT NULL DEFAULT '{}'::jsonb,
    imported_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    PRIMARY KEY (task_id, footnote_index)
);

COMMENT ON TABLE pdf2md.footnotes IS '脚注/注释索引。来源 content_list_enhanced.footnotes。';
COMMENT ON COLUMN pdf2md.footnotes.task_id IS '关联 documents.task_id，表示脚注所属解析任务。';
COMMENT ON COLUMN pdf2md.footnotes.footnote_index IS '脚注序号，按 content_list_enhanced.footnotes 顺序生成。';
COMMENT ON COLUMN pdf2md.footnotes.page_number IS '脚注所在 PDF 页码，如来源可识别。';
COMMENT ON COLUMN pdf2md.footnotes.markdown_line IS '脚注在 Markdown 中的行号，如来源可识别。';
COMMENT ON COLUMN pdf2md.footnotes.text IS '脚注文本内容。';
COMMENT ON COLUMN pdf2md.footnotes.raw IS '脚注原始 JSON。';
COMMENT ON COLUMN pdf2md.footnotes.imported_at IS '该脚注写入数据库的时间。';

CREATE TABLE IF NOT EXISTS pdf2md.toc_entries (
    task_id TEXT NOT NULL REFERENCES pdf2md.documents(task_id) ON DELETE CASCADE,
    toc_index INTEGER NOT NULL,
    title TEXT,
    level INTEGER,
    page_number INTEGER,
    markdown_line INTEGER,
    raw JSONB NOT NULL DEFAULT '{}'::jsonb,
    imported_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    PRIMARY KEY (task_id, toc_index)
);

COMMENT ON TABLE pdf2md.toc_entries IS '目录/标题候选索引。来源 content_list_enhanced.toc。';
COMMENT ON COLUMN pdf2md.toc_entries.task_id IS '关联 documents.task_id，表示目录项所属解析任务。';
COMMENT ON COLUMN pdf2md.toc_entries.toc_index IS '目录项序号，按 content_list_enhanced.toc 顺序生成。';
COMMENT ON COLUMN pdf2md.toc_entries.title IS '目录或标题候选文本。';
COMMENT ON COLUMN pdf2md.toc_entries.level IS '目录层级或标题层级。';
COMMENT ON COLUMN pdf2md.toc_entries.page_number IS '目录项指向的 PDF 页码，如来源可识别。';
COMMENT ON COLUMN pdf2md.toc_entries.markdown_line IS '目录项在 Markdown 中的行号，如来源可识别。';
COMMENT ON COLUMN pdf2md.toc_entries.raw IS '目录项原始 JSON。';
COMMENT ON COLUMN pdf2md.toc_entries.imported_at IS '该目录项写入数据库的时间。';

CREATE TABLE IF NOT EXISTS pdf2md.financial_note_links (
    task_id TEXT NOT NULL REFERENCES pdf2md.documents(task_id) ON DELETE CASCADE,
    link_index INTEGER NOT NULL,
    item_name TEXT,
    canonical_name TEXT,
    note_title TEXT,
    note_ref TEXT,
    table_index INTEGER,
    page_number INTEGER,
    raw JSONB NOT NULL DEFAULT '{}'::jsonb,
    imported_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    PRIMARY KEY (task_id, link_index)
);

COMMENT ON TABLE pdf2md.financial_note_links IS '财报项目与附注关联。来源 content_list_enhanced.financial_note_links。';
COMMENT ON COLUMN pdf2md.financial_note_links.task_id IS '关联 documents.task_id，表示附注关联所属解析任务。';
COMMENT ON COLUMN pdf2md.financial_note_links.link_index IS '附注关联序号，按 content_list_enhanced.financial_note_links 顺序生成。';
COMMENT ON COLUMN pdf2md.financial_note_links.item_name IS '主表财务项目名称，如 应收账款、存货、营业收入。';
COMMENT ON COLUMN pdf2md.financial_note_links.canonical_name IS '财务项目标准化名称，如 operating_revenue。';
COMMENT ON COLUMN pdf2md.financial_note_links.note_title IS '关联附注标题。';
COMMENT ON COLUMN pdf2md.financial_note_links.note_ref IS '关联附注编号或引用标识。';
COMMENT ON COLUMN pdf2md.financial_note_links.table_index IS '关联主表或附注表格编号。';
COMMENT ON COLUMN pdf2md.financial_note_links.page_number IS '关联附注所在 PDF 页码。';
COMMENT ON COLUMN pdf2md.financial_note_links.raw IS '附注关联原始 JSON。';
COMMENT ON COLUMN pdf2md.financial_note_links.imported_at IS '该附注关联写入数据库的时间。';

CREATE TABLE IF NOT EXISTS pdf2md.financial_statements (
    task_id TEXT NOT NULL REFERENCES pdf2md.documents(task_id) ON DELETE CASCADE,
    statement_id TEXT NOT NULL,
    statement_type TEXT,
    statement_name TEXT,
    scope TEXT,
    scope_name TEXT,
    title TEXT,
    unit TEXT,
    scale NUMERIC,
    currency TEXT,
    table_indexes JSONB NOT NULL DEFAULT '[]'::jsonb,
    line_numbers JSONB NOT NULL DEFAULT '[]'::jsonb,
    columns JSONB NOT NULL DEFAULT '[]'::jsonb,
    raw JSONB NOT NULL DEFAULT '{}'::jsonb,
    imported_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    PRIMARY KEY (task_id, statement_id)
);

COMMENT ON TABLE pdf2md.financial_statements IS '财务报表表头级信息。来源 financial_data.statements，每张资产负债表/利润表/现金流量表等一行。';
COMMENT ON COLUMN pdf2md.financial_statements.task_id IS '关联 documents.task_id，表示该财务报表所属解析任务。';
COMMENT ON COLUMN pdf2md.financial_statements.statement_id IS '报表 ID，来源 statements[].statement_id。';
COMMENT ON COLUMN pdf2md.financial_statements.statement_type IS '报表类型，如 balance_sheet、income_statement、cash_flow_statement。';
COMMENT ON COLUMN pdf2md.financial_statements.statement_name IS '报表中文名称，如 资产负债表、利润表、现金流量表。';
COMMENT ON COLUMN pdf2md.financial_statements.scope IS '报表口径，如 consolidated、parent_company。';
COMMENT ON COLUMN pdf2md.financial_statements.scope_name IS '报表口径中文名称，如 合并、母公司。';
COMMENT ON COLUMN pdf2md.financial_statements.title IS '报表标题，来源 financial_data.statements[].title。';
COMMENT ON COLUMN pdf2md.financial_statements.unit IS '报表金额单位文本。';
COMMENT ON COLUMN pdf2md.financial_statements.scale IS '数值缩放倍数，例如万元对应 10000。';
COMMENT ON COLUMN pdf2md.financial_statements.currency IS '币种，如 CNY。';
COMMENT ON COLUMN pdf2md.financial_statements.table_indexes IS '该报表对应的表格编号数组。';
COMMENT ON COLUMN pdf2md.financial_statements.line_numbers IS '该报表在 Markdown 中对应的行号数组。';
COMMENT ON COLUMN pdf2md.financial_statements.columns IS '期间列定义，来源 statements[].columns。';
COMMENT ON COLUMN pdf2md.financial_statements.raw IS '单张报表原始 JSON。';
COMMENT ON COLUMN pdf2md.financial_statements.imported_at IS '该财务报表记录写入数据库的时间。';

CREATE TABLE IF NOT EXISTS pdf2md.financial_statement_items (
    task_id TEXT NOT NULL REFERENCES pdf2md.documents(task_id) ON DELETE CASCADE,
    statement_id TEXT NOT NULL,
    item_index INTEGER NOT NULL,
    period_key TEXT NOT NULL,
    item_name TEXT,
    canonical_name TEXT,
    value NUMERIC,
    raw_value TEXT,
    source JSONB NOT NULL DEFAULT '{}'::jsonb,
    raw_item JSONB NOT NULL DEFAULT '{}'::jsonb,
    imported_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    PRIMARY KEY (task_id, statement_id, item_index, period_key)
);

COMMENT ON TABLE pdf2md.financial_statement_items IS '财务报表项目事实表。来源 financial_data.statements[].items[].values，每个项目/期间一行，适合 SQL 分析和跨公司比较。';
COMMENT ON COLUMN pdf2md.financial_statement_items.task_id IS '关联 documents.task_id，表示该财务项目所属解析任务。';
