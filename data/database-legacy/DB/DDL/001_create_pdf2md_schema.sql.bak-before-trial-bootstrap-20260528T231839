COMMENT ON COLUMN pdf2md.evaluation_results.eval_run_id IS '关联 evaluation_runs.eval_run_id。';
COMMENT ON COLUMN pdf2md.evaluation_results.metric_name IS '评测指标名称，如 accuracy、precision、acceptance_rate。';
COMMENT ON COLUMN pdf2md.evaluation_results.total_count IS '评测样本总数。';
COMMENT ON COLUMN pdf2md.evaluation_results.correct_count IS '评测正确样本数。';
COMMENT ON COLUMN pdf2md.evaluation_results.accuracy IS '准确率或达成率。';
