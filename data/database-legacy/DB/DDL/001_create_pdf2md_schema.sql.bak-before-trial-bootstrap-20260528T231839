CREATE TABLE IF NOT EXISTS pdf2md.evaluation_runs (
    eval_run_id TEXT PRIMARY KEY,
    task_id TEXT REFERENCES pdf2md.documents(task_id) ON DELETE CASCADE,
    parse_run_id TEXT REFERENCES pdf2md.parse_runs(parse_run_id) ON DELETE SET NULL,
    eval_type TEXT NOT NULL,
    evaluator_version TEXT,
    started_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    completed_at TIMESTAMPTZ,
    raw JSONB NOT NULL DEFAULT '{}'::jsonb
);

COMMENT ON TABLE pdf2md.evaluation_runs IS '评测运行表。记录一次指标精度、检索成功率、报告采纳率等评测任务。';
COMMENT ON COLUMN pdf2md.evaluation_runs.eval_run_id IS '评测运行主键。';
COMMENT ON COLUMN pdf2md.evaluation_runs.task_id IS '关联 documents.task_id。';
COMMENT ON COLUMN pdf2md.evaluation_runs.parse_run_id IS '关联 parse_runs.parse_run_id。';
COMMENT ON COLUMN pdf2md.evaluation_runs.eval_type IS '评测类型，如 extraction_accuracy、retrieval_success、report_acceptance。';
COMMENT ON COLUMN pdf2md.evaluation_runs.evaluator_version IS '评测器版本。';
COMMENT ON COLUMN pdf2md.evaluation_runs.started_at IS '评测开始时间。';
COMMENT ON COLUMN pdf2md.evaluation_runs.completed_at IS '评测完成时间。';
COMMENT ON COLUMN pdf2md.evaluation_runs.raw IS '评测运行原始 JSON。';

CREATE TABLE IF NOT EXISTS pdf2md.evaluation_results (
    eval_result_id TEXT PRIMARY KEY,
    eval_run_id TEXT NOT NULL REFERENCES pdf2md.evaluation_runs(eval_run_id) ON DELETE CASCADE,
    metric_name TEXT NOT NULL,
    total_count INTEGER,
    correct_count INTEGER,
    accuracy NUMERIC,
    tolerance NUMERIC,
    details JSONB NOT NULL DEFAULT '{}'::jsonb,
    created_at TIMESTAMPTZ NOT NULL DEFAULT now()
