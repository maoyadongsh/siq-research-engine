+from market_report_finder_service.markets.kr.catalog import KR_ANNUAL_REPORT_CATALOG, KrAnnualReportCatalog
+
+
+TARGET_TICKERS = (
+    "005930",
+    "000660",
+    "035420",
+    "005380",
+    "003490",
+    "005490",
+    "051910",
