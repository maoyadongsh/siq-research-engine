+
+
+def _content_list_enhanced(
+    document_full: dict[str, Any],
+    fallback: dict[str, Any] | None = None,
+) -> dict[str, Any]:
+    enhanced = document_full.get("content_list_enhanced")
+    if not (isinstance(enhanced, dict) and enhanced):
