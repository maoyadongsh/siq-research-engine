REPORT_FINDER_ENV=dev
REPORT_FINDER_ENABLE_BROWSER_FALLBACK=false
REPORT_FINDER_ALLOWED_SOURCES=cninfo,hkex,sec
REPORT_FINDER_BROWSER_USE_PROVIDER=openai
REPORT_FINDER_BROWSER_USE_MODEL=gpt-4.1-mini
REPORT_FINDER_BROWSER_USE_API_KEY=
REPORT_FINDER_BROWSER_USE_HEADLESS=true
REPORT_FINDER_BROWSER_USE_CHROMIUM_SANDBOX=false
REPORT_FINDER_ENABLE_COMPANY_MAPPING_AGENT=false
REPORT_FINDER_COMPANY_MAPPING_BASE_URL=https://api.openai.com/v1
REPORT_FINDER_COMPANY_MAPPING_MODEL=gpt-4.1-mini
REPORT_FINDER_COMPANY_MAPPING_API_KEY=
REPORT_FINDER_HTTP_TIMEOUT_SECONDS=20
REPORT_FINDER_SEC_USER_AGENT=ReportFinderService contact@example.com
REPORT_FINDER_DOWNLOAD_DIR=../../data/report-finder/downloads
REPORT_FINDER_DOWNLOAD_OVERWRITE=false
