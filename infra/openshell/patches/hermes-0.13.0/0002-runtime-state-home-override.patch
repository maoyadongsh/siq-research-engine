+def get_hermes_runtime_home() -> Path:
+    """Return the optional directory dedicated to mutable runtime state.
+
+    Normal Hermes installations retain the historical HERMES_HOME layout.
+    Sandboxed deployments may isolate SQLite and gateway metadata from the
+    read-only profile control plane with HERMES_RUNTIME_HOME.
+    """
+    value = os.environ.get("HERMES_RUNTIME_HOME", "").strip()
+    if not value:
+        return get_hermes_home()
+    path = Path(value)
+    if not path.is_absolute() or ".." in path.parts:
+        raise RuntimeError(
+            "HERMES_RUNTIME_HOME must be an absolute traversal-free path"
+        )
+    return Path(os.path.normpath(path))
+
+
