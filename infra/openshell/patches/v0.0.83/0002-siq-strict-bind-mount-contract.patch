+fn validated_bind_mount_project_root(config: &DockerComputeConfig) -> CoreResult<Option<PathBuf>> {
+    if !config.enable_bind_mounts {
+        if !config.bind_mount_contract.is_empty() || config.bind_mount_project_root.is_some() {
+            return Err(Error::config(
+                "bind_mount_contract and bind_mount_project_root require enable_bind_mounts = true",
+            ));
+        }
+        return Ok(None);
+    }
+    if config.bind_mount_contract != SIQ_ANALYSIS_BIND_MOUNT_CONTRACT {
+        return Err(Error::config(format!(
+            "enabled Docker bind mounts require bind_mount_contract = '{SIQ_ANALYSIS_BIND_MOUNT_CONTRACT}'",
+        )));
+    }
+    let root = config.bind_mount_project_root.as_deref().ok_or_else(|| {
+        Error::config("enabled Docker bind mounts require bind_mount_project_root")
+    })?;
+    if !root.is_absolute()
+        || root
+            .components()
+            .any(|component| matches!(component, std::path::Component::ParentDir))
+    {
+        return Err(Error::config(
+            "bind_mount_project_root must be an absolute normalized path",
+        ));
+    }
+    let canonical = root.canonicalize().map_err(|_| {
+        Error::config("bind_mount_project_root must exist and resolve to a directory")
+    })?;
+    if canonical != root || !canonical.is_dir() {
+        return Err(Error::config(
+            "bind_mount_project_root must be canonical, symlink-free, and a directory",
+        ));
+    }
+    Ok(Some(canonical))
+}
