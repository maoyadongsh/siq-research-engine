+fn validate_siq_analysis_bind_mounts(
+    mounts: &[DockerDriverMountConfig],
+    project_root: &Path,
+) -> Result<(), Status> {
+    if mounts.is_empty() {
+        return Ok(());
+    }
+    if mounts.len() != SIQ_ANALYSIS_MOUNT_COUNT {
+        return Err(Status::failed_precondition(
+            "SIQ analysis bind contract requires exactly 7 mounts",
+        ));
+    }
+
+    let wiki = project_root.join("data/wiki");
+    let runtime_root = project_root.join("var/openshell/siq-analysis/runtime-snapshots");
+    let hermes_root = project_root.join("data/hermes/home/profiles/siq_analysis");
+    let runtime_directories = [
+        "runtime-state",
+        "sessions",
+        "checkpoints",
+        "cron",
+        "memories",
+    ];
+    let required_runtime_names = runtime_directories.iter().copied().collect::<HashSet<_>>();
+    let mut observed_runtime_names = HashSet::new();
+    let mut observed_run_id: Option<String> = None;
+    let mut wiki_mounts = 0usize;
+    let mut analysis_mounts = 0usize;
+
+    for mount in mounts {
+        let DockerDriverMountConfig::Bind {
+            source,
+            target,
+            read_only,
+            selinux_label,
+        } = mount
+        else {
+            return Err(Status::failed_precondition(
+                "SIQ analysis bind contract permits bind mounts only",
+            ));
+        };
+        if selinux_label.is_some() {
+            return Err(Status::failed_precondition(
+                "SIQ analysis bind contract forbids SELinux relabelling",
+            ));
+        }
+        let canonical = canonical_siq_bind_source(source, project_root)?;
+        let target_path = Path::new(target);
+
+        if canonical == wiki {
+            if !read_only || target_path != wiki {
+                return Err(Status::failed_precondition(
+                    "SIQ wiki mount must preserve its path and remain read-only",
+                ));
+            }
+            if !canonical.is_dir() {
+                return Err(Status::failed_precondition(
+                    "SIQ wiki source must be a directory",
+                ));
+            }
+            wiki_mounts += 1;
+            continue;
+        }
+
+        if is_siq_analysis_task_path(project_root, &canonical) {
+            if *read_only || target_path != canonical {
+                return Err(Status::failed_precondition(
+                    "SIQ task analysis mount must preserve its path and be read-write",
+                ));
+            }
+            if !canonical.is_dir() {
+                return Err(Status::failed_precondition(
+                    "SIQ task analysis source must be a directory",
+                ));
+            }
+            analysis_mounts += 1;
+            continue;
+        }
+
+        let relative = canonical.strip_prefix(&runtime_root).map_err(|_| {
+            Status::failed_precondition("SIQ bind source is outside the fixed mount contract")
+        })?;
+        let components = relative
+            .components()
+            .map(|component| component.as_os_str().to_string_lossy().into_owned())
+            .collect::<Vec<_>>();
+        if components.len() != 2 || !validate_siq_analysis_run_id(&components[0]) {
+            return Err(Status::failed_precondition(
+                "SIQ runtime source must use one validated task snapshot",
+            ));
+        }
+        let run_id = &components[0];
+        let name = &components[1];
+        if observed_run_id
+            .as_ref()
+            .is_some_and(|value| value != run_id)
+        {
+            return Err(Status::failed_precondition(
+                "SIQ runtime mounts must share one task snapshot",
+            ));
+        }
+        observed_run_id.get_or_insert_with(|| run_id.clone());
+        let expected_target = if name == "runtime-state" {
+            PathBuf::from("/sandbox/siq-analysis-runtime-state")
+        } else {
+            hermes_root.join(name)
+        };
+        if !required_runtime_names.contains(name.as_str())
+            || !observed_runtime_names.insert(name.clone())
+            || *read_only
+            || target_path != expected_target
+        {
+            return Err(Status::failed_precondition(
+                "SIQ runtime mount name, mode, or target is outside the fixed contract",
+            ));
+        }
+        if !runtime_directories.contains(&name.as_str()) || !canonical.is_dir() {
+            return Err(Status::failed_precondition(
+                "SIQ runtime source type does not match the fixed contract",
+            ));
+        }
+    }
+
+    if wiki_mounts != 1
+        || analysis_mounts != 1
+        || observed_runtime_names.len() != required_runtime_names.len()
+        || !required_runtime_names
+            .iter()
+            .all(|name| observed_runtime_names.contains(*name))
+    {
+        return Err(Status::failed_precondition(
+            "SIQ analysis bind mount set is incomplete or duplicated",
+        ));
+    }
+    Ok(())
+}
