+fn siq_mounts_json(mounts: &[DockerDriverMountConfig]) -> Vec<serde_json::Value> {
+    mounts
+        .iter()
+        .map(|mount| match mount {
+            DockerDriverMountConfig::Bind {
+                source,
+                target,
+                read_only,
+                selinux_label,
+            } => {
+                assert!(selinux_label.is_none());
+                serde_json::json!({
+                    "type": "bind",
+                    "source": source,
+                    "target": target,
+                    "read_only": read_only,
+                })
+            }
+            _ => panic!("expected SIQ bind mount"),
+        })
+        .collect()
+}
