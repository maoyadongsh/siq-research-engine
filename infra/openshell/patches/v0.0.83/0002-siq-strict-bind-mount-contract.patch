+fn validate_siq_analysis_run_id(value: &str) -> bool {
+    !value.is_empty()
+        && value.len() <= 48
+        && value.as_bytes()[0].is_ascii_alphanumeric()
+        && value
+            .bytes()
+            .all(|byte| byte.is_ascii_lowercase() || byte.is_ascii_digit() || byte == b'-')
+}
+
+fn validate_siq_company_segment(value: &str) -> bool {
+    let mut characters = value.chars();
+    let Some(first) = characters.next() else {
+        return false;
+    };
+    if !first.is_alphanumeric() || value.len() > 255 {
+        return false;
+    }
+    let mut count = 1usize;
+    for character in characters {
+        count += 1;
+        if count > 128
+            || !(character.is_alphanumeric()
+                || matches!(character, '-' | '_' | '.' | '(' | ')' | '（' | '）'))
+        {
+            return false;
+        }
+    }
+    true
+}
+
+fn is_siq_analysis_task_path(project_root: &Path, source: &Path) -> bool {
+    let Ok(relative) = source.strip_prefix(project_root) else {
+        return false;
+    };
+    let Some(value) = relative.to_str() else {
+        return false;
+    };
+    let parts = value.split('/').collect::<Vec<_>>();
+    (parts.len() == 5
+        && parts[0..3] == ["data", "wiki", "companies"]
+        && validate_siq_company_segment(parts[3])
+        && parts[4] == "analysis")
+        || (parts.len() == 6
+            && parts[0..2] == ["data", "wiki"]
+            && matches!(parts[2], "eu" | "hk" | "jp" | "kr" | "us")
+            && parts[3] == "companies"
+            && validate_siq_company_segment(parts[4])
+            && parts[5] == "analysis")
+}
+
+fn canonical_siq_bind_source(source: &str, project_root: &Path) -> Result<PathBuf, Status> {
+    let source_path = PathBuf::from(source);
+    if source_path.components().any(|component| {
+        matches!(
+            component,
+            std::path::Component::CurDir | std::path::Component::ParentDir
+        )
+    }) {
+        return Err(Status::failed_precondition(
+            "SIQ bind source must be normalized and must not contain '.' or '..'",
+        ));
+    }
+    let canonical = source_path
+        .canonicalize()
+        .map_err(|_| Status::failed_precondition("SIQ bind source must exist and be canonical"))?;
+    if canonical != source_path || !canonical.starts_with(project_root) {
+        return Err(Status::failed_precondition(
+            "SIQ bind source must be symlink-free and remain inside the configured project root",
+        ));
+    }
+    Ok(canonical)
+}
