+/// Restrict a rule's access mask to rights valid for the opened path type.
+///
+/// `AccessFs::from_read()` and `AccessFs::from_all()` both contain
+/// directory-only rights. Passing either mask unchanged for a regular file or
+/// device makes `PathBeneath` reject the rule before it reaches the kernel.
+/// Inspect the already-open `PathFd` to avoid a pathname TOCTOU window.
+fn access_for_path_fd(
+    path_fd: &PathFd,
+    path: &Path,
+    requested: BitFlags<AccessFs>,
+    abi: ABI,
+) -> Result<BitFlags<AccessFs>> {
+    let stat = nix::sys::stat::fstat(path_fd.as_fd().as_raw_fd()).map_err(|err| {
+        miette::miette!(
+            "failed to inspect Landlock path type {}: {err}",
+            path.display()
+        )
+    })?;
+    let file_type = nix::sys::stat::SFlag::from_bits_truncate(stat.st_mode);
+    if file_type.contains(nix::sys::stat::SFlag::S_IFDIR) {
+        return Ok(requested);
+    }
+    Ok(requested & AccessFs::from_file(abi))
+}
