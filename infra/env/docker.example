# Safe Docker Compose template.

SIQ_COMPOSE_BIND_HOST=127.0.0.1
SIQ_DEPLOYMENT_PROFILE=local
SIQ_DATA_ROOT=/state/data
SIQ_RUNTIME_ROOT=/state/runtime
SIQ_ARTIFACTS_ROOT=/state/artifacts
SIQ_PDF2MD_DATA_DIR=/state/runtime/pdf-parser
SIQ_PDF_RESULTS_ROOT=/state/artifacts/pdf-parser/results
SIQ_PDF_OUTPUT_ROOT=/state/artifacts/pdf-parser/output
SIQ_DOCUMENT_PARSE_DATA_DIR=/state/runtime/document-parser
SIQ_DOCUMENT_PARSE_RESULTS_ROOT=/state/artifacts/document-parser/results
SIQ_DOCUMENT_OUTPUT_ROOT=/state/artifacts/document-parser/output
SIQ_REPORT_DOWNLOADS_ROOT=/state/artifacts/market-report-finder/downloads
SIQ_WEB_MEM_LIMIT=768m
SIQ_WEB_CPUS=1.0
SIQ_API_MEM_LIMIT=3g
SIQ_API_CPUS=2.0
SIQ_PDF2MD_MEM_LIMIT=2g
SIQ_PDF2MD_CPUS=2.0
SIQ_DOCUMENT_PARSER_MEM_LIMIT=2g
SIQ_DOCUMENT_PARSER_CPUS=2.0
SIQ_REPORT_FINDER_MEM_LIMIT=1g
SIQ_REPORT_FINDER_CPUS=1.0
SIQ_MARKET_REPORT_RULES_MEM_LIMIT=1g
SIQ_MARKET_REPORT_RULES_CPUS=1.0
SIQ_POSTGRES_MEM_LIMIT=2g
SIQ_POSTGRES_CPUS=2.0
SIQ_REDIS_MEM_LIMIT=512m
SIQ_REDIS_CPUS=1.0
SIQ_GRAFANA_MEM_LIMIT=512m
SIQ_GRAFANA_CPUS=1.0
SIQ_SECURITY_ARTIFACT_DIR=artifacts/security

SIQ_AUTH_SECRET_KEY=replace-with-at-least-32-random-characters
SIQ_AUTH_COOKIE_MODE=0
SIQ_AUTH_COOKIE_SECURE=0
SIQ_AUTH_COOKIE_SAMESITE=lax
SIQ_SOURCE_TOKEN_SECRET=replace-with-different-at-least-32-random-characters
SIQ_SOURCE_ACCEPT_LEGACY_AUTH_SECRET=0
SIQ_ALLOW_REGISTRATION=0
SIQ_DEMO_MODE=0

POSTGRES_PASSWORD=replace-with-postgres-password
SIQ_POSTGRES_IMAGE=postgres:16-alpine
# Default compose storage uses the postgres_data named volume. To reuse an
# existing bind mount without moving data automatically, set:
# SIQ_POSTGRES_DATA_VOLUME=../../data/postgres
# The compose Postgres init scripts create siq_app, siq_document_parser,
# siq_us, siq_hk, siq_jp, siq_kr, and siq_eu on first volume initialization.
SIQ_AGENT_MEMORY_ENABLED=true
SIQ_AGENT_MEMORY_WRITE_ENABLED=true
SIQ_AGENT_MEMORY_RETRIEVAL_ENABLED=true
SIQ_AGENT_MEMORY_VECTOR_BACKEND=milvus
SIQ_AGENT_MEMORY_PGVECTOR_ENABLED=false
SIQ_AGENT_MEMORY_EXTRACTION_ENABLED=true
SIQ_AGENT_MEMORY_SCHEMA=agent_memory
SIQ_AGENT_MEMORY_MILVUS_COLLECTION=siq_agent_memory
SIQ_AGENT_MEMORY_EMBEDDING_DIM=1024
SIQ_AGENT_MEMORY_EMBEDDING_BASE_URL=http://host.docker.internal:8013
SIQ_AGENT_MEMORY_EMBEDDING_MODEL=Qwen3-VL-Embedding-2B
SIQ_AGENT_MEMORY_RERANK_ENABLED=true
SIQ_RERANK_BASE_URL=http://host.docker.internal:8001
SIQ_RERANK_MODEL=Qwen3-VL-Reranker-2B
SIQ_AGENT_MEMORY_DEFAULT_VISIBILITY=user_private
SIQ_AGENT_MEMORY_PRIMARY_MARKET_VISIBILITY=project_shared
SIQ_AGENT_MEMORY_MAX_ITEMS=8
SIQ_AGENT_MEMORY_FULL_RECALL_MAX_ITEMS=25
SIQ_AGENT_MEMORY_MAX_TOKENS=1800
SIQ_AGENT_MEMORY_MIN_SCORE=0.72
SIQ_AGENT_MEMORY_RETRIEVAL_BUDGET_MS=1200
SIQ_AGENT_MEMORY_RERANK_TIMEOUT=1.0
SIQ_AGENT_MEMORY_MIN_QUERY_CHARS=4
SIQ_AGENT_MEMORY_TIME_DECAY_ENABLED=true
SIQ_AGENT_MEMORY_TIME_DECAY_HALF_LIFE_DAYS=30
SIQ_AGENT_MEMORY_TIME_DECAY_FLOOR=0.35
SIQ_MILVUS_HOST=host.docker.internal
SIQ_MILVUS_PORT=19530
PDF2MD_ACCESS_TOKEN=replace-with-pdf-parser-token
SIQ_DOCUMENT_PARSER_ACCESS_TOKEN=replace-with-document-parser-token
GRAFANA_PASSWORD=replace-with-grafana-password
SIQ_GRAFANA_IMAGE=grafana/grafana:12.0.2

MINERU_API_URL=http://host.docker.internal:8003
VLM_API_URL=http://host.docker.internal:8002
