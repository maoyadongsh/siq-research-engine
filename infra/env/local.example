# Safe local development template for SIQ Research Engine.
# Copy values into your own ignored env file if needed; do not put real secrets here.

SIQ_PROJECT_ROOT=/home/maoyd/siq-research-engine
SIQ_DEPLOYMENT_PROFILE=local

# Runtime roots. Compatibility default keeps existing repo data/var/artifacts.
# New local setups should prefer an external state root, for example:
# SIQ_LOCAL_STATE_ROOT=/home/maoyd/.local/state/siq-research-engine
SIQ_LOCAL_STATE_ROOT=/home/maoyd/siq-research-engine
SIQ_DATA_ROOT=${SIQ_LOCAL_STATE_ROOT}/data
SIQ_RUNTIME_ROOT=${SIQ_LOCAL_STATE_ROOT}/var
SIQ_ARTIFACTS_ROOT=${SIQ_LOCAL_STATE_ROOT}/artifacts
SIQ_DATASETS_ROOT=${SIQ_PROJECT_ROOT}/datasets

SIQ_AUTH_SECRET_KEY=replace-with-at-least-32-random-characters
SIQ_AUTH_COOKIE_MODE=0
SIQ_AUTH_COOKIE_SECURE=0
SIQ_AUTH_COOKIE_SAMESITE=lax
SIQ_SOURCE_TOKEN_SECRET=replace-with-different-at-least-32-random-characters
SIQ_SOURCE_ACCEPT_LEGACY_AUTH_SECRET=0
SIQ_ALLOW_REGISTRATION=0
SIQ_DEMO_MODE=0
SIQ_INITIAL_ADMIN_PASSWORD=replace-with-strong-admin-password
SIQ_CREATE_DEMO_USERS=0

SIQ_APP_DATABASE_URL=postgresql+psycopg://postgres:replace-with-local-postgres-password@127.0.0.1:15432/siq_app
REDIS_URL=redis://localhost:16379/0

SIQ_AGENT_MEMORY_ENABLED=true
SIQ_AGENT_MEMORY_WRITE_ENABLED=true
SIQ_AGENT_MEMORY_RETRIEVAL_ENABLED=true
SIQ_AGENT_MEMORY_VECTOR_BACKEND=milvus
SIQ_AGENT_MEMORY_PGVECTOR_ENABLED=false
SIQ_AGENT_MEMORY_EXTRACTION_ENABLED=true
SIQ_AGENT_MEMORY_SCHEMA=agent_memory
SIQ_AGENT_MEMORY_MILVUS_COLLECTION=siq_agent_memory
SIQ_AGENT_MEMORY_EMBEDDING_DIM=1024
SIQ_AGENT_MEMORY_EMBEDDING_BASE_URL=http://127.0.0.1:8013
SIQ_AGENT_MEMORY_EMBEDDING_MODEL=Qwen3-VL-Embedding-2B
SIQ_AGENT_MEMORY_RERANK_ENABLED=true
SIQ_RERANK_BASE_URL=http://127.0.0.1:8001
SIQ_RERANK_MODEL=Qwen3-VL-Reranker-2B
SIQ_AGENT_MEMORY_DEFAULT_VISIBILITY=user_private
SIQ_AGENT_MEMORY_PRIMARY_MARKET_VISIBILITY=project_shared
SIQ_AGENT_MEMORY_MAX_ITEMS=8
SIQ_AGENT_MEMORY_FULL_RECALL_MAX_ITEMS=25
SIQ_AGENT_MEMORY_MAX_TOKENS=1800
SIQ_AGENT_MEMORY_MIN_SCORE=0.72
SIQ_AGENT_MEMORY_RETRIEVAL_BUDGET_MS=1200
SIQ_AGENT_MEMORY_RERANK_TIMEOUT=1.0
SIQ_AGENT_MEMORY_MIN_QUERY_CHARS=4
SIQ_AGENT_MEMORY_TIME_DECAY_ENABLED=true
SIQ_AGENT_MEMORY_TIME_DECAY_HALF_LIFE_DAYS=30
SIQ_AGENT_MEMORY_TIME_DECAY_FLOOR=0.35
SIQ_MILVUS_HOST=127.0.0.1
SIQ_MILVUS_PORT=19530

SIQ_WIKI_ROOT=${SIQ_DATA_ROOT}/wiki
SIQ_ASSISTANT_WIKI_ROOT=${SIQ_DATA_ROOT}/wiki
SIQ_DEFAULT_SOURCE_TYPE=wiki_metrics
SIQ_ASSISTANT_DEFAULT_SOURCE_TYPE=wiki_metrics

SIQ_BACKEND_ROOT=${SIQ_PROJECT_ROOT}/apps/api
SIQ_FRONTEND_ROOT=${SIQ_PROJECT_ROOT}/apps/web
SIQ_PDF2MD_ROOT=${SIQ_PROJECT_ROOT}/apps/pdf-parser
SIQ_PDF2MD_DATA_DIR=${SIQ_DATA_ROOT}/pdf-parser
SIQ_DOCUMENT_PARSER_ROOT=${SIQ_PROJECT_ROOT}/apps/document-parser
SIQ_DOCUMENT_PARSE_DATA_DIR=${SIQ_DATA_ROOT}/document-parser
SIQ_REPORT_FINDER_ROOT=${SIQ_PROJECT_ROOT}/services/market-report-finder
SIQ_MARKET_REPORT_FINDER_ROOT=${SIQ_PROJECT_ROOT}/services/market-report-finder
SIQ_MARKET_REPORT_RULES_ROOT=${SIQ_PROJECT_ROOT}/services/market-report-rules
SIQ_REPORT_DOWNLOADS_ROOT=${SIQ_DATA_ROOT}/market-report-finder/downloads
SIQ_MARKET_REPORT_DOWNLOADS_ROOT=${SIQ_DATA_ROOT}/market-report-finder/downloads

SIQ_DB_ROOT=${SIQ_PROJECT_ROOT}/db
SIQ_DOCUMENT_PGDATABASE=siq_document_parser
SIQ_US_PGDATABASE=siq_us
SIQ_HK_PGDATABASE=siq_hk
SIQ_JP_PGDATABASE=siq_jp
SIQ_KR_PGDATABASE=siq_kr
SIQ_EU_PGDATABASE=siq_eu
SIQ_HERMES_HOME=${SIQ_DATA_ROOT}/hermes/home
SIQ_HERMES_PROFILES_ROOT=${SIQ_HERMES_HOME}/profiles
SIQ_MINERU_VENV=${SIQ_PROJECT_ROOT}/runtimes/mineru-native

SIQ_BACKEND_PORT=18081
SIQ_FRONTEND_PORT=15173
SIQ_PDF2MD_PORT=15000
SIQ_DOCUMENT_PARSER_PORT=15010
SIQ_REPORT_FINDER_PORT=18000
SIQ_MARKET_REPORT_FINDER_PORT=18010
SIQ_MARKET_REPORT_RULES_PORT=18020
SIQ_POSTGRES_PORT=15432
SIQ_REDIS_PORT=16379
SIQ_GRAFANA_PORT=13001
SIQ_COMPOSE_BIND_HOST=127.0.0.1
SIQ_BACKEND_URL=http://127.0.0.1:18081
SIQ_REPORT_FINDER_URL=http://127.0.0.1:18000
SIQ_MARKET_REPORT_FINDER_URL=http://127.0.0.1:18010
SIQ_MARKET_REPORT_RULES_URL=http://127.0.0.1:18020
SIQ_PDFAPI_URL=http://127.0.0.1:15000
SIQ_REPORT_FINDER_BASE=http://127.0.0.1:18000
SIQ_MARKET_REPORT_FINDER_BASE=http://127.0.0.1:18010
SIQ_MARKET_REPORT_RULES_BASE=http://127.0.0.1:18020
SIQ_PDF2MD_API_BASE=http://127.0.0.1:15000
SIQ_DOCUMENT_PARSER_API_BASE=http://127.0.0.1:15010
SIQ_REPORT_FINDER_HEALTH_URL=http://127.0.0.1:18000/health
SIQ_MARKET_REPORT_FINDER_HEALTH_URL=http://127.0.0.1:18010/health
SIQ_MARKET_REPORT_RULES_HEALTH_URL=http://127.0.0.1:18020/healthz
SIQ_PDF2MD_HEALTH_URL=http://127.0.0.1:15000/api/health
SIQ_DOCUMENT_PARSER_HEALTH_URL=http://127.0.0.1:15010/api/health
SIQ_PUBLIC_ORIGIN=http://localhost:15173
SIQ_START_HERMES_GATEWAYS=1
SIQ_START_MARKET_REPORT_FINDER=0
SIQ_START_MARKET_REPORT_RULES=0
SIQ_START_VECTOR_INGEST=0
SIQ_MILVUS_COLLECTION=ic_collaboration_shared

# Optional official market data API keys for Korea/Japan report downloads.
DART_API_KEY=replace-with-opendart-key
EDINET_API_KEY=replace-with-edinet-key-if-required

SIQ_HERMES_ASSISTANT_PORT=18642
SIQ_HERMES_FACTCHECKER_PORT=18649
SIQ_HERMES_TRACKING_PORT=18650
SIQ_HERMES_ANALYSIS_PORT=18651
SIQ_HERMES_LEGAL_PORT=18652

PDF2MD_ACCESS_TOKEN=replace-with-pdf-parser-token
SIQ_DOCUMENT_PARSER_ACCESS_TOKEN=replace-with-document-parser-token
MINERU_API_URL=http://127.0.0.1:8003
VLM_API_URL=http://127.0.0.1:8002

POSTGRES_PASSWORD=replace-with-local-postgres-password
SIQ_POSTGRES_IMAGE=postgres:16-alpine
GRAFANA_PASSWORD=replace-with-local-grafana-password
SIQ_GRAFANA_IMAGE=grafana/grafana:12.0.2
