# Safe local development template for SIQ Research Engine.
# Copy values into your own ignored env file if needed; do not put real secrets here.

SIQ_PROJECT_ROOT=/home/maoyd/siq-research-engine
SIQ_AUTH_SECRET_KEY=replace-with-at-least-32-random-characters
SIQ_ALLOW_REGISTRATION=0
SIQ_DEMO_MODE=0
SIQ_INITIAL_ADMIN_PASSWORD=replace-with-strong-admin-password
SIQ_CREATE_DEMO_USERS=0

DATABASE_URL=sqlite:////home/maoyd/siq-research-engine/data/backend/agent.db
REDIS_URL=redis://localhost:16379/0

SIQ_WIKI_ROOT=/home/maoyd/siq-research-engine/data/wiki
SIQ_ASSISTANT_WIKI_ROOT=/home/maoyd/siq-research-engine/data/wiki
SIQ_DEFAULT_SOURCE_TYPE=wiki_metrics
SIQ_ASSISTANT_DEFAULT_SOURCE_TYPE=wiki_metrics

SIQ_BACKEND_ROOT=/home/maoyd/siq-research-engine/apps/api
SIQ_FRONTEND_ROOT=/home/maoyd/siq-research-engine/apps/web
SIQ_PDF2MD_ROOT=/home/maoyd/siq-research-engine/apps/pdf-parser
SIQ_PDF2MD_DATA_DIR=/home/maoyd/siq-research-engine/data/pdf-parser
SIQ_REPORT_FINDER_ROOT=/home/maoyd/siq-research-engine/services/market-report-finder
SIQ_MARKET_REPORT_FINDER_ROOT=/home/maoyd/siq-research-engine/services/market-report-finder
SIQ_MARKET_REPORT_RULES_ROOT=/home/maoyd/siq-research-engine/services/market-report-rules
SIQ_REPORT_DOWNLOADS_ROOT=/home/maoyd/siq-research-engine/data/market-report-finder/downloads
SIQ_MARKET_REPORT_DOWNLOADS_ROOT=/home/maoyd/siq-research-engine/data/market-report-finder/downloads

SIQ_DB_ROOT=/home/maoyd/siq-research-engine/db
SIQ_HERMES_HOME=/home/maoyd/siq-research-engine/data/hermes/home
SIQ_HERMES_PROFILES_ROOT=/home/maoyd/siq-research-engine/data/hermes/home/profiles
SIQ_MINERU_VENV=/home/maoyd/siq-research-engine/runtimes/mineru_native

SIQ_BACKEND_PORT=18081
SIQ_FRONTEND_PORT=15173
SIQ_PDF2MD_PORT=15000
SIQ_REPORT_FINDER_PORT=18000
SIQ_MARKET_REPORT_FINDER_PORT=18010
SIQ_MARKET_REPORT_RULES_PORT=18020
SIQ_POSTGRES_PORT=15432
SIQ_REDIS_PORT=16379
SIQ_GRAFANA_PORT=13001
SIQ_BACKEND_URL=http://127.0.0.1:18081
SIQ_REPORT_FINDER_URL=http://127.0.0.1:18000
SIQ_MARKET_REPORT_FINDER_URL=http://127.0.0.1:18010
SIQ_MARKET_REPORT_RULES_URL=http://127.0.0.1:18020
SIQ_PDFAPI_URL=http://127.0.0.1:15000
SIQ_REPORT_FINDER_BASE=http://127.0.0.1:18000
SIQ_MARKET_REPORT_FINDER_BASE=http://127.0.0.1:18010
SIQ_MARKET_REPORT_RULES_BASE=http://127.0.0.1:18020
SIQ_PDF2MD_API_BASE=http://127.0.0.1:15000
SIQ_REPORT_FINDER_HEALTH_URL=http://127.0.0.1:18000/health
SIQ_MARKET_REPORT_FINDER_HEALTH_URL=http://127.0.0.1:18010/health
SIQ_MARKET_REPORT_RULES_HEALTH_URL=http://127.0.0.1:18020/healthz
SIQ_PDF2MD_HEALTH_URL=http://127.0.0.1:15000/api/health
SIQ_PUBLIC_ORIGIN=http://localhost:15173
SIQ_START_MARKET_REPORT_FINDER=0
SIQ_START_MARKET_REPORT_RULES=0

# Optional official market data API keys for Korea/Japan report downloads.
DART_API_KEY=replace-with-opendart-key
EDINET_API_KEY=replace-with-edinet-key-if-required

SIQ_HERMES_ASSISTANT_PORT=18642
SIQ_HERMES_FACTCHECKER_PORT=18649
SIQ_HERMES_TRACKING_PORT=18650
SIQ_HERMES_ANALYSIS_PORT=18651
SIQ_HERMES_LEGAL_PORT=18652

