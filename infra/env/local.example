# Safe local development template for SIQ Research Engine.
# Copy values into your own ignored env file if needed; do not put real secrets here.

SIQ_PROJECT_ROOT=/home/maoyd/siq-research-engine
SIQ_DEPLOYMENT_PROFILE=local
SIQ_METRICS_TOKEN=

# Runtime roots. Compatibility default keeps existing repo data/runtime/artifacts.
# New local setups should prefer an external state root, for example:
# SIQ_LOCAL_STATE_ROOT=/home/maoyd/.local/state/siq-research-engine
SIQ_LOCAL_STATE_ROOT=/home/maoyd/siq-research-engine
SIQ_DATA_ROOT=${SIQ_LOCAL_STATE_ROOT}/data
SIQ_RUNTIME_ROOT=${SIQ_LOCAL_STATE_ROOT}/runtime
SIQ_ARTIFACTS_ROOT=${SIQ_LOCAL_STATE_ROOT}/artifacts
SIQ_DATASETS_ROOT=${SIQ_PROJECT_ROOT}/datasets
SIQ_REPORT_REVIEW_ROOT=${SIQ_ARTIFACTS_ROOT}
SIQ_REPORT_REVIEW_MAX_BYTES=10485760

SIQ_AUTH_SECRET_KEY=replace-with-at-least-32-random-characters
SIQ_CORS_ALLOW_ORIGINS=http://localhost:15173,http://127.0.0.1:15173
SIQ_AUTH_COOKIE_MODE=0
SIQ_AUTH_COOKIE_SECURE=0
SIQ_AUTH_COOKIE_SAMESITE=lax
SIQ_SOURCE_TOKEN_SECRET=replace-with-different-at-least-32-random-characters
SIQ_SOURCE_ACCEPT_LEGACY_AUTH_SECRET=0
SIQ_ALLOW_REGISTRATION=0
SIQ_DEMO_MODE=0
SIQ_INITIAL_ADMIN_PASSWORD=replace-with-strong-admin-password
SIQ_CREATE_DEMO_USERS=0

SIQ_APP_DATABASE_URL=postgresql+psycopg://postgres:replace-with-local-postgres-password@127.0.0.1:15432/siq_app
REDIS_URL=redis://localhost:16379/0
SIQ_BACKGROUND_JOB_BACKEND=file
SIQ_BACKGROUND_JOB_LEASE_SECONDS=120

SIQ_AGENT_MEMORY_ENABLED=true
SIQ_AGENT_MEMORY_WRITE_ENABLED=true
SIQ_AGENT_MEMORY_RETRIEVAL_ENABLED=true
SIQ_AGENT_MEMORY_VECTOR_BACKEND=milvus
SIQ_AGENT_MEMORY_PGVECTOR_ENABLED=false
SIQ_AGENT_MEMORY_EXTRACTION_ENABLED=true
SIQ_AGENT_MEMORY_SCHEMA=agent_memory
SIQ_AGENT_MEMORY_MILVUS_COLLECTION=siq_agent_memory_active
SIQ_AGENT_MEMORY_EMBEDDING_DIM=1024
SIQ_AGENT_MEMORY_EMBEDDING_BASE_URL=http://127.0.0.1:8013
SIQ_AGENT_MEMORY_EMBEDDING_MODEL=Qwen3-VL-Embedding-2B
SIQ_AGENT_MEMORY_RERANK_ENABLED=true
SIQ_RERANK_BASE_URL=http://127.0.0.1:8001
SIQ_RERANK_MODEL=Qwen3-VL-Reranker-2B
SIQ_AGENT_MEMORY_DEFAULT_VISIBILITY=user_private
SIQ_AGENT_MEMORY_PRIMARY_MARKET_VISIBILITY=project_shared
SIQ_AGENT_MEMORY_MAX_ITEMS=8
SIQ_AGENT_MEMORY_FULL_RECALL_MAX_ITEMS=25
SIQ_AGENT_MEMORY_MAX_TOKENS=1800
SIQ_AGENT_MEMORY_MIN_SCORE=0.72
SIQ_AGENT_MEMORY_RETRIEVAL_BUDGET_MS=1200
SIQ_AGENT_MEMORY_RERANK_TIMEOUT=1.0
SIQ_AGENT_MEMORY_MIN_QUERY_CHARS=4
SIQ_AGENT_MEMORY_TIME_DECAY_ENABLED=true
SIQ_AGENT_MEMORY_TIME_DECAY_HALF_LIFE_DAYS=30
SIQ_AGENT_MEMORY_TIME_DECAY_FLOOR=0.35
SIQ_MILVUS_HOST=127.0.0.1
SIQ_MILVUS_PORT=19530

SIQ_WIKI_ROOT=${SIQ_DATA_ROOT}/wiki
SIQ_ASSISTANT_WIKI_ROOT=${SIQ_DATA_ROOT}/wiki
SIQ_DEFAULT_SOURCE_TYPE=wiki_metrics
SIQ_ASSISTANT_DEFAULT_SOURCE_TYPE=wiki_metrics
SIQ_FINANCIAL_GUARDRAIL_MODE=warn
SIQ_IMAGE_MODEL_ENABLED=true
SIQ_IMAGE_MODEL_BASE_URL=http://127.0.0.1:8007/v1
SIQ_IMAGE_MODEL=nemotron_3_nano_omni
SIQ_FUNASR_BASE_URL=http://127.0.0.1:8899/asr
SIQ_FUNASR_TIMEOUT_SECONDS=90
SIQ_CHAT_VOICE_MAX_BYTES=10485760
SIQ_CHAT_VOICE_MAX_SECONDS=60

# Meeting transcription is additive and remains fully off by default.
SIQ_MEETINGS_ENABLED=0
SIQ_MEETING_REALTIME_ASR_ENABLED=0
SIQ_MEETING_CORRECTION_LEARNING_ENABLED=0
SIQ_MEETING_AI_ENABLED=0
SIQ_MEETING_VOICEPRINT_ENABLED=0
SIQ_MEETING_IMPORT_ENABLED=0
SIQ_MEETING_IOS_NATIVE_CAPTURE_ENABLED=0
SIQ_MEETING_NATIVE_CAPTURE_ROOT=${SIQ_DATA_ROOT}/backend/meeting_native_captures
SIQ_MEETING_NATIVE_CAPTURE_TOKEN_TTL_SECONDS=86400
SIQ_MEETING_NATIVE_CAPTURE_MAX_BATCH_BYTES=8388608
SIQ_MEETING_NATIVE_CAPTURE_MAX_TOTAL_BYTES=4294967296
SIQ_MEETING_NATIVE_CAPTURE_MAX_RETAINED_BYTES_PER_OWNER=17179869184
SIQ_MEETING_NATIVE_CAPTURE_MAX_DURATION_SECONDS=14400
SIQ_MEETING_NATIVE_CAPTURE_MAX_ACTIVE_PER_OWNER=2
SIQ_MEETING_NATIVE_CAPTURE_MAX_BATCH_CONCURRENCY=8
SIQ_MEETING_NATIVE_CAPTURE_BATCH_QUEUE_TIMEOUT_SECONDS=2
SIQ_MEETING_NATIVE_CAPTURE_MIN_STORAGE_FREE_BYTES=536870912
SIQ_MEETING_NATIVE_FINALIZATION_LEASE_SECONDS=300
SIQ_MEETING_NATIVE_FINALIZATION_RETRY_DELAY_SECONDS=20
SIQ_MEETING_NATIVE_FINALIZATION_POLL_SECONDS=1
SIQ_MEETING_NATIVE_FINALIZATION_MAX_ATTEMPTS=5
SIQ_MEETING_IMPORT_ROOT=${SIQ_DATA_ROOT}/backend/meeting_imports
SIQ_MEETING_IMPORT_MAX_FILE_BYTES=4294967296
SIQ_MEETING_IMPORT_OWNER_QUOTA_BYTES=8589934592
SIQ_MEETING_IMPORT_MAX_ACTIVE_PER_OWNER=3
SIQ_MEETING_IMPORT_MIN_CHUNK_BYTES=262144
SIQ_MEETING_IMPORT_MAX_CHUNK_BYTES=16777216
SIQ_MEETING_IMPORT_MAX_DURATION_SECONDS=14400
SIQ_MEETING_IMPORT_UPLOAD_TTL_SECONDS=86400
# Set absolute paths when ffmpeg/ffprobe are not on the service PATH.
SIQ_MEETING_IMPORT_FFMPEG_BIN=ffmpeg
SIQ_MEETING_IMPORT_FFPROBE_BIN=ffprobe
SIQ_MEETING_SYSTEM_AUDIO_ENABLED=0
SIQ_MEETING_ASR_WS_URL=ws://127.0.0.1:8901/v1/stream/{meeting_id}
SIQ_MEETING_FINAL_ASR_MAX_CONCURRENCY=2
SIQ_MEETING_FINAL_ASR_WINDOW_OVERLAP_MS=2000
SIQ_MEETING_SPEECH_HTTP_FINALIZER_MAX_CONCURRENCY=2
SIQ_MEETING_SPEECH_FINALIZATION_MAX_SESSIONS=2
SIQ_MEETING_SPEECH_FINALIZATION_MAX_CACHED_WINDOWS=2048
SIQ_MEETING_STREAM_GATEWAY_MODE=embedded
SIQ_MEETING_STREAM_GATEWAY_HOST=127.0.0.1
SIQ_MEETING_STREAM_GATEWAY_PORT=18082
SIQ_MEETING_STREAM_GATEWAY_URL=http://127.0.0.1:18082
SIQ_MEETING_AUDIO_ROOT=${SIQ_DATA_ROOT}/backend/meeting_audio
SIQ_MEETING_MAX_DURATION_SECONDS=14400
SIQ_MEETING_AUDIO_MAX_FRAME_BYTES=262144
# Active capacity is counted from unexpired database stream leases.
SIQ_MEETING_MAX_ACTIVE_PER_USER=1
SIQ_MEETING_MAX_ACTIVE_TOTAL=4
# Dual per-connection token bucket; PCM payload bytes exclude the 32-byte header.
SIQ_MEETING_AUDIO_MAX_FRAMES_PER_SECOND=20
SIQ_MEETING_AUDIO_MAX_BYTES_PER_SECOND=128000
SIQ_MEETING_AUDIO_RATE_BURST_SECONDS=2
SIQ_MEETING_RECONNECT_BUFFER_SECONDS=60
SIQ_MEETING_STREAM_TICKET_TTL_SECONDS=45
SIQ_MEETING_STREAM_LEASE_TTL_SECONDS=20
SIQ_MEETING_STREAM_HANDSHAKE_TIMEOUT_SECONDS=10
SIQ_MEETING_PLAYBACK_TICKET_TTL_SECONDS=900
SIQ_MEETING_SPEAKER_EMBEDDING_URL=http://127.0.0.1:8901/v1/speaker/embedding
# The speech embedding endpoint is independently gated and remains off until
# an approved speaker evaluation and rollout explicitly enable it.
SIQ_MEETING_SPEECH_EMBEDDING_ENDPOINT_ENABLED=0
# Whole-meeting reclustering uses request-scoped embeddings only. These
# temporary vectors must not be written to PostgreSQL or Milvus.
SIQ_MEETING_SPEAKER_RECLUSTER_EMBEDDING_URL=http://127.0.0.1:8901/v1/speaker/embedding
# Exact base final-ASR diarizer identity; required only for validated auto-merge.
SIQ_MEETING_SPEAKER_RECLUSTER_FINAL_DIARIZER_REF=
SIQ_MEETING_SPEAKER_RECLUSTER_ENCODER_REF=iic/speech_eres2netv2_sv_zh-cn_16k-common
# Deliberately unvalidated. Keep the approved report outside the repository;
# validation_artifact_sha256 is the SHA-256 of that immutable report.
SIQ_MEETING_SPEAKER_RECLUSTER_POLICY_JSON='{"schema_version":"siq.meeting.speaker_recluster_policy.v1","version":"speaker-recluster.unvalidated.v1","auto_apply_validated":false,"validation_artifact_sha256":null,"review_min_score":0.72,"merge_min_score":0.82,"singleton_merge_min_score":0.92,"min_top2_margin":0.04,"min_segment_ms":1500,"max_segment_ms":8000,"max_samples_per_track":4,"max_total_samples":256,"max_tracks":64,"max_noise_level":0.65,"min_asr_confidence":0.45,"min_rms":0.003,"max_clipping_ratio":0.01}'
# Set to the approved report only when enabling cross-key automatic merge.
SIQ_MEETING_SPEAKER_RECLUSTER_VALIDATION_REPORT=
# Independent operator authorization for embedding-based cross-key merge only.
SIQ_MEETING_SPEAKER_RECLUSTER_AUTO_APPLY_ENABLED=0
SIQ_MEETING_SPEECH_INTERNAL_SERVICE_TOKEN=replace-with-shared-internal-speech-token
SIQ_MEETINGS_HERMES_TARGETS_FILE=${SIQ_RUNTIME_ROOT}/meetings/hermes-targets.json
SIQ_MEETINGS_HERMES_API_KEY=replace-with-meeting-gateway-token
SIQ_MEETINGS_MODEL_ALLOWLIST=nemotron_3_nano_omni,kimi-for-coding
SIQ_MEETING_DEFAULT_MODEL_REF=meeting:kimi-for-coding:4c226b751833
SIQ_MEETING_PROVIDER_CREDENTIAL_FILES=
SIQ_MEETINGS_HERMES_PORT_BASE=18710
SIQ_MEETING_MODEL_CATALOG_TTL_SECONDS=15
SIQ_MEETING_VOICEPRINT_ENCODER_REF=iic/speech_eres2netv2_sv_zh-cn_16k-common
SIQ_MEETING_VOICEPRINT_ENCODER_NAME=funasr-eres2netv2
SIQ_MEETING_VOICEPRINT_ENCODER_VERSION=iic/speech_eres2netv2_sv_zh-cn_16k-common
SIQ_MEETINGS_VOICEPRINT_KEY_ID=local-v1
SIQ_MEETINGS_VOICEPRINT_KEYRING_JSON='{"local-v1":"SIQ_MEETING_VOICEPRINT_KEY_LOCAL_V1"}'
SIQ_MEETING_VOICEPRINT_KEY_LOCAL_V1=replace-with-base64url-encoded-32-byte-key
# This append-only ledger must remain outside SIQ_BACKEND_DATA_ROOT and database backups.
SIQ_MEETING_VOICEPRINT_TOMBSTONE_PATH=${SIQ_RUNTIME_ROOT}/security/meeting-voiceprint-tombstones.jsonl
SIQ_MEETING_VOICEPRINT_TOMBSTONE_HMAC_KEY=replace-with-a-different-base64url-encoded-32-byte-key
# Example shape only. Replace scores/margins with validation-set output before enabling.
SIQ_MEETING_VOICEPRINT_THRESHOLDS_JSON='{"version":"replace-with-calibrated-threshold-version","suggestion_min_score":0.80,"suggestion_min_margin":0.12,"auto_min_score":0.92,"auto_min_margin":0.20,"min_effective_duration_ms":6000,"allowed_quality_grades":["good"],"auto_match_validated":false}'
SIQ_MEETING_VOICEPRINT_AUTO_MATCH_ENABLED=0
SIQ_MEETING_DELETE_WORKER_ENABLED=0
SIQ_MEETING_RETENTION_SCAN_ENABLED=0
SIQ_MEETING_AUDIO_RETENTION_DAYS=90
SIQ_MEETING_DELETION_TOMBSTONE_PATH=${SIQ_RUNTIME_ROOT}/security/meeting-deletion-tombstones.jsonl
SIQ_MEETING_DELETION_TOMBSTONE_HMAC_KEY=replace-with-a-third-base64url-encoded-32-byte-key

SIQ_BACKEND_ROOT=${SIQ_PROJECT_ROOT}/apps/api
SIQ_FRONTEND_ROOT=${SIQ_PROJECT_ROOT}/apps/web
SIQ_PDF2MD_ROOT=${SIQ_PROJECT_ROOT}/apps/pdf-parser
