# Production deployment template for SIQ Research Engine.
# Copy to a secret-managed environment, replace every placeholder, and keep real values out of Git.

SIQ_PROJECT_ROOT=/opt/siq-research-engine
SIQ_DEPLOYMENT_PROFILE=production
SIQ_METRICS_TOKEN=replace-with-secret-manager-value
SIQ_LOCAL_STATE_ROOT=/var/lib/siq-research-engine
SIQ_DATA_ROOT=/var/lib/siq-research-engine/data
SIQ_RUNTIME_ROOT=/var/lib/siq-research-engine/runtime
SIQ_ARTIFACTS_ROOT=/var/lib/siq-research-engine/artifacts
SIQ_DATASETS_ROOT=/opt/siq-research-engine/datasets
SIQ_REPORT_REVIEW_ROOT=/var/lib/siq-research-engine/artifacts
SIQ_REPORT_REVIEW_MAX_BYTES=10485760

SIQ_AUTH_SECRET_KEY=replace-with-at-least-32-random-characters
SIQ_AUTH_COOKIE_MODE=1
SIQ_AUTH_COOKIE_SECURE=1
SIQ_AUTH_COOKIE_SAMESITE=lax
SIQ_SOURCE_TOKEN_SECRET=replace-with-different-at-least-32-random-characters
SIQ_SOURCE_ACCEPT_LEGACY_AUTH_SECRET=0
SIQ_ALLOW_REGISTRATION=0
SIQ_DEMO_MODE=0
SIQ_INITIAL_ADMIN_PASSWORD=replace-with-secret-manager-value
SIQ_CREATE_DEMO_USERS=0

SIQ_APP_DATABASE_URL=postgresql+psycopg://siq:replace-with-db-password@postgres.example.internal:5432/siq_app
REDIS_URL=redis://redis.example.internal:6379/0
SIQ_BACKGROUND_JOB_BACKEND=postgres
SIQ_BACKGROUND_JOB_LEASE_SECONDS=120

SIQ_AGENT_MEMORY_ENABLED=true
SIQ_AGENT_MEMORY_WRITE_ENABLED=true
SIQ_AGENT_MEMORY_RETRIEVAL_ENABLED=true
SIQ_AGENT_MEMORY_VECTOR_BACKEND=milvus
SIQ_AGENT_MEMORY_PGVECTOR_ENABLED=false
SIQ_AGENT_MEMORY_EXTRACTION_ENABLED=true
SIQ_AGENT_MEMORY_SCHEMA=agent_memory
SIQ_AGENT_MEMORY_MILVUS_COLLECTION=siq_agent_memory_active
SIQ_AGENT_MEMORY_EMBEDDING_DIM=1024
SIQ_AGENT_MEMORY_EMBEDDING_BASE_URL=https://embedding.example.internal
SIQ_AGENT_MEMORY_EMBEDDING_MODEL=Qwen3-VL-Embedding-2B
SIQ_AGENT_MEMORY_RERANK_ENABLED=true
SIQ_RERANK_BASE_URL=https://reranker.example.internal
SIQ_RERANK_MODEL=Qwen3-VL-Reranker-2B
SIQ_AGENT_MEMORY_DEFAULT_VISIBILITY=user_private
SIQ_AGENT_MEMORY_PRIMARY_MARKET_VISIBILITY=project_shared
SIQ_AGENT_MEMORY_MAX_ITEMS=8
SIQ_AGENT_MEMORY_FULL_RECALL_MAX_ITEMS=25
SIQ_AGENT_MEMORY_MAX_TOKENS=1800
SIQ_AGENT_MEMORY_MIN_SCORE=0.72
SIQ_AGENT_MEMORY_RETRIEVAL_BUDGET_MS=1200
SIQ_AGENT_MEMORY_RERANK_TIMEOUT=1.0
SIQ_AGENT_MEMORY_MIN_QUERY_CHARS=4
SIQ_AGENT_MEMORY_TIME_DECAY_ENABLED=true
SIQ_AGENT_MEMORY_TIME_DECAY_HALF_LIFE_DAYS=30
SIQ_AGENT_MEMORY_TIME_DECAY_FLOOR=0.35
SIQ_MILVUS_HOST=milvus.example.internal
SIQ_MILVUS_PORT=19530
HERMES_API_KEY=replace-with-hermes-gateway-token
SIQ_HERMES_ASSISTANT_RUNS_URL=https://hermes-assistant.example.internal/v1/runs
SIQ_FUNASR_BASE_URL=http://funasr.example.internal:8899/asr
SIQ_FUNASR_TIMEOUT_SECONDS=90
SIQ_CHAT_VOICE_MAX_BYTES=10485760
SIQ_CHAT_VOICE_MAX_SECONDS=60

# Meeting transcription is additive and remains fully off by default. Inject
# every token/key below from the runtime secret manager.
SIQ_MEETINGS_ENABLED=0
SIQ_MEETING_REALTIME_ASR_ENABLED=0
SIQ_MEETING_CORRECTION_LEARNING_ENABLED=0
SIQ_MEETING_AI_ENABLED=0
SIQ_MEETING_VOICEPRINT_ENABLED=0
SIQ_MEETING_IMPORT_ENABLED=0
SIQ_MEETING_IOS_NATIVE_CAPTURE_ENABLED=0
SIQ_MEETING_NATIVE_CAPTURE_ROOT=/var/lib/siq-research-engine/data/backend/meeting_native_captures
SIQ_MEETING_NATIVE_CAPTURE_TOKEN_TTL_SECONDS=86400
SIQ_MEETING_NATIVE_CAPTURE_MAX_BATCH_BYTES=8388608
SIQ_MEETING_NATIVE_CAPTURE_MAX_TOTAL_BYTES=4294967296
SIQ_MEETING_NATIVE_CAPTURE_MAX_RETAINED_BYTES_PER_OWNER=17179869184
SIQ_MEETING_NATIVE_CAPTURE_MAX_DURATION_SECONDS=14400
SIQ_MEETING_NATIVE_CAPTURE_MAX_ACTIVE_PER_OWNER=2
SIQ_MEETING_NATIVE_CAPTURE_MAX_BATCH_CONCURRENCY=8
SIQ_MEETING_NATIVE_CAPTURE_BATCH_QUEUE_TIMEOUT_SECONDS=2
SIQ_MEETING_NATIVE_CAPTURE_MIN_STORAGE_FREE_BYTES=536870912
SIQ_MEETING_NATIVE_FINALIZATION_LEASE_SECONDS=300
SIQ_MEETING_NATIVE_FINALIZATION_RETRY_DELAY_SECONDS=20
SIQ_MEETING_NATIVE_FINALIZATION_POLL_SECONDS=1
SIQ_MEETING_NATIVE_FINALIZATION_MAX_ATTEMPTS=5
SIQ_MEETING_IMPORT_ROOT=/var/lib/siq-research-engine/data/backend/meeting_imports
SIQ_MEETING_IMPORT_MAX_FILE_BYTES=4294967296
SIQ_MEETING_IMPORT_OWNER_QUOTA_BYTES=8589934592
SIQ_MEETING_IMPORT_MAX_ACTIVE_PER_OWNER=3
SIQ_MEETING_IMPORT_MIN_CHUNK_BYTES=262144
SIQ_MEETING_IMPORT_MAX_CHUNK_BYTES=16777216
SIQ_MEETING_IMPORT_MAX_DURATION_SECONDS=14400
SIQ_MEETING_IMPORT_UPLOAD_TTL_SECONDS=86400
SIQ_MEETING_IMPORT_FFMPEG_BIN=/usr/bin/ffmpeg
SIQ_MEETING_IMPORT_FFPROBE_BIN=/usr/bin/ffprobe
SIQ_MEETING_SYSTEM_AUDIO_ENABLED=0
SIQ_MEETING_ASR_WS_URL=wss://meeting-speech.example.internal/v1/stream/{meeting_id}
SIQ_MEETING_FINAL_ASR_MAX_CONCURRENCY=2
SIQ_MEETING_FINAL_ASR_WINDOW_OVERLAP_MS=2000
SIQ_MEETING_SPEECH_HTTP_FINALIZER_MAX_CONCURRENCY=2
SIQ_MEETING_SPEECH_FINALIZATION_MAX_SESSIONS=2
SIQ_MEETING_SPEECH_FINALIZATION_MAX_CACHED_WINDOWS=2048
SIQ_MEETING_STREAM_GATEWAY_MODE=external
SIQ_MEETING_STREAM_GATEWAY_HOST=127.0.0.1
SIQ_MEETING_STREAM_GATEWAY_PORT=18082
SIQ_MEETING_STREAM_GATEWAY_URL=http://127.0.0.1:18082
SIQ_MEETING_AUDIO_ROOT=/var/lib/siq-research-engine/data/backend/meeting_audio
SIQ_MEETING_MAX_DURATION_SECONDS=14400
SIQ_MEETING_AUDIO_MAX_FRAME_BYTES=262144
# Size these two values from the approved release concurrency benchmark.
SIQ_MEETING_MAX_ACTIVE_PER_USER=1
SIQ_MEETING_MAX_ACTIVE_TOTAL=4
# Per-connection dual token bucket. Invalid injected values fail closed.
SIQ_MEETING_AUDIO_MAX_FRAMES_PER_SECOND=20
SIQ_MEETING_AUDIO_MAX_BYTES_PER_SECOND=128000
SIQ_MEETING_AUDIO_RATE_BURST_SECONDS=2
SIQ_MEETING_RECONNECT_BUFFER_SECONDS=60
SIQ_MEETING_STREAM_TICKET_TTL_SECONDS=45
SIQ_MEETING_STREAM_LEASE_TTL_SECONDS=20
SIQ_MEETING_STREAM_HANDSHAKE_TIMEOUT_SECONDS=10
SIQ_MEETING_PLAYBACK_TICKET_TTL_SECONDS=900
SIQ_MEETING_SPEAKER_EMBEDDING_URL=https://meeting-speech.example.internal/v1/speaker/embedding
# Keep disabled until the approved diarization/voiceprint evidence, policy,
# and operator gate are bound to this release candidate.
SIQ_MEETING_SPEECH_EMBEDDING_ENDPOINT_ENABLED=0
# Whole-meeting reclustering uses request-scoped embeddings only. These
# temporary vectors must not be written to PostgreSQL or Milvus.
SIQ_MEETING_SPEAKER_RECLUSTER_EMBEDDING_URL=https://meeting-speech.example.internal/v1/speaker/embedding
# Exact base final-ASR diarizer identity; required only for validated auto-merge.
SIQ_MEETING_SPEAKER_RECLUSTER_FINAL_DIARIZER_REF=
SIQ_MEETING_SPEAKER_RECLUSTER_ENCODER_REF=iic/speech_eres2netv2_sv_zh-cn_16k-common
# Deliberately unvalidated. Keep the approved report in the restricted evidence
# store; validation_artifact_sha256 is the SHA-256 of that immutable report.
SIQ_MEETING_SPEAKER_RECLUSTER_POLICY_JSON='{"schema_version":"siq.meeting.speaker_recluster_policy.v1","version":"speaker-recluster.unvalidated.v1","auto_apply_validated":false,"validation_artifact_sha256":null,"review_min_score":0.72,"merge_min_score":0.82,"singleton_merge_min_score":0.92,"min_top2_margin":0.04,"min_segment_ms":1500,"max_segment_ms":8000,"max_samples_per_track":4,"max_total_samples":256,"max_tracks":64,"max_noise_level":0.65,"min_asr_confidence":0.45,"min_rms":0.003,"max_clipping_ratio":0.01}'
# Mount one approved bounded report and set its absolute path only for rollout.
SIQ_MEETING_SPEAKER_RECLUSTER_VALIDATION_REPORT=
# Independent operator authorization for embedding-based cross-key merge only.
SIQ_MEETING_SPEAKER_RECLUSTER_AUTO_APPLY_ENABLED=0
SIQ_MEETING_SPEECH_INTERNAL_SERVICE_TOKEN=replace-with-secret-manager-value
SIQ_MEETINGS_HERMES_TARGETS_FILE=/var/lib/siq-research-engine/runtime/meetings/hermes-targets.json
SIQ_MEETINGS_HERMES_API_KEY=replace-with-secret-manager-value
SIQ_MEETINGS_MODEL_ALLOWLIST=
SIQ_MEETING_DEFAULT_MODEL_REF=
SIQ_MEETING_PROVIDER_CREDENTIAL_FILES=
SIQ_MEETINGS_HERMES_PORT_BASE=18710
SIQ_MEETING_MODEL_CATALOG_TTL_SECONDS=15
SIQ_MEETING_VOICEPRINT_ENCODER_REF=iic/speech_eres2netv2_sv_zh-cn_16k-common
SIQ_MEETING_VOICEPRINT_ENCODER_NAME=funasr-eres2netv2
SIQ_MEETING_VOICEPRINT_ENCODER_VERSION=iic/speech_eres2netv2_sv_zh-cn_16k-common
SIQ_MEETINGS_VOICEPRINT_KEY_ID=production-v1
SIQ_MEETINGS_VOICEPRINT_KEYRING_JSON='{"production-v1":"SIQ_MEETING_VOICEPRINT_KEY_PRODUCTION_V1"}'
SIQ_MEETING_VOICEPRINT_KEY_PRODUCTION_V1=replace-with-secret-manager-value
# Mount this append-only ledger outside SIQ_BACKEND_DATA_ROOT and database backup media.
SIQ_MEETING_VOICEPRINT_TOMBSTONE_PATH=/var/lib/siq-research-engine/security/meeting-voiceprint-tombstones.jsonl
SIQ_MEETING_VOICEPRINT_TOMBSTONE_HMAC_KEY=replace-with-a-separate-secret-manager-value
# Example shape only. Production rollout requires an immutable validation artifact.
SIQ_MEETING_VOICEPRINT_THRESHOLDS_JSON='{"version":"replace-with-calibrated-threshold-version","suggestion_min_score":0.80,"suggestion_min_margin":0.12,"auto_min_score":0.92,"auto_min_margin":0.20,"min_effective_duration_ms":6000,"allowed_quality_grades":["good"],"auto_match_validated":false}'
SIQ_MEETING_VOICEPRINT_AUTO_MATCH_ENABLED=0
SIQ_MEETING_DELETE_WORKER_ENABLED=0
SIQ_MEETING_RETENTION_SCAN_ENABLED=0
SIQ_MEETING_AUDIO_RETENTION_DAYS=90
SIQ_MEETING_DELETION_TOMBSTONE_PATH=/var/lib/siq-research-engine/security/meeting-deletion-tombstones.jsonl
SIQ_MEETING_DELETION_TOMBSTONE_HMAC_KEY=replace-with-a-third-secret-manager-value

# Controlled release gates. Keep tokens and restore credentials in the runtime
# secret manager; do not persist them in release reports. The live endpoint must
# use HTTPS without embedded credentials/query tokens. The restore backup path
# must be absolute and point to one approved, complete backup manifest.
SIQ_LIVE_MODEL_BENCHMARK_MODE=live-http
SIQ_LIVE_MODEL_BENCHMARK_REQUIRED=1
SIQ_LIVE_MODEL_URL=https://hermes-assistant.example.internal/v1/runs
SIQ_LIVE_MODEL_PROTOCOL=auto
SIQ_LIVE_MODEL_TIMEOUT=120
SIQ_LIVE_MODEL_NAME=replace-with-deployed-model-identity
SIQ_LIVE_MODEL_AUTH_TOKEN=replace-with-secret-manager-value
SIQ_PRODUCTION_CONFIG_REQUIRED=1
SIQ_PERMISSION_NEGATIVE_GATE_REQUIRED=1
SIQ_RESTORE_MATRIX_REQUIRED=1
SIQ_RESTORE_MATRIX_BACKUP_DIR=/approved/backup/replace-with-approved-backup-timestamp
SIQ_RESTORE_MATRIX_ADMIN_URL=postgresql://restore_user:replace-with-secret-manager-value@restore-postgres.example.internal:5432/postgres
SIQ_RESTORE_MATRIX_VOICEPRINT_TOMBSTONE_REQUIRED=1

SIQ_WIKI_ROOT=/var/lib/siq-research-engine/data/wiki
SIQ_ASSISTANT_WIKI_ROOT=/var/lib/siq-research-engine/data/wiki
SIQ_DEFAULT_SOURCE_TYPE=wiki_metrics
SIQ_ASSISTANT_DEFAULT_SOURCE_TYPE=wiki_metrics
SIQ_FINANCIAL_GUARDRAIL_MODE=block

SIQ_BACKEND_ROOT=/opt/siq-research-engine/apps/api
SIQ_FRONTEND_ROOT=/opt/siq-research-engine/apps/web
SIQ_PDF2MD_ROOT=/opt/siq-research-engine/apps/pdf-parser
SIQ_PDF2MD_DATA_DIR=/var/lib/siq-research-engine/runtime/pdf-parser
SIQ_PDF_RESULTS_ROOT=/var/lib/siq-research-engine/artifacts/pdf-parser/results
SIQ_PDF_OUTPUT_ROOT=/var/lib/siq-research-engine/artifacts/pdf-parser/output
SIQ_DOCUMENT_PARSER_ROOT=/opt/siq-research-engine/apps/document-parser
SIQ_DOCUMENT_PARSE_DATA_DIR=/var/lib/siq-research-engine/runtime/document-parser
SIQ_DOCUMENT_PARSE_RESULTS_ROOT=/var/lib/siq-research-engine/artifacts/document-parser/results
SIQ_DOCUMENT_OUTPUT_ROOT=/var/lib/siq-research-engine/artifacts/document-parser/output
SIQ_REPORT_FINDER_ROOT=/opt/siq-research-engine/services/market-report-finder
SIQ_MARKET_REPORT_FINDER_ROOT=/opt/siq-research-engine/services/market-report-finder
SIQ_MARKET_REPORT_RULES_ROOT=/opt/siq-research-engine/services/market-report-rules
SIQ_MARKET_REPORT_FINDER_TOKEN=replace-with-secret-manager-value
SIQ_MARKET_REPORT_RULES_TOKEN=replace-with-secret-manager-value
SIQ_REPORT_DOWNLOADS_ROOT=/var/lib/siq-research-engine/artifacts/market-report-finder/downloads
SIQ_MARKET_REPORT_DOWNLOADS_ROOT=/var/lib/siq-research-engine/artifacts/market-report-finder/downloads

SIQ_DB_ROOT=/opt/siq-research-engine/db
SIQ_DOCUMENT_PGDATABASE=siq_document_parser
SIQ_US_PGDATABASE=siq_us
SIQ_HK_PGDATABASE=siq_hk
SIQ_JP_PGDATABASE=siq_jp
SIQ_KR_PGDATABASE=siq_kr
SIQ_EU_PGDATABASE=siq_eu
SIQ_HERMES_HOME=/var/lib/siq-research-engine/runtime/hermes/home
SIQ_HERMES_PROFILES_ROOT=/var/lib/siq-research-engine/runtime/hermes/home/profiles
# Must be the exact host HERMES_HOME used by the Hermes gateway. Compose mounts
# this directory read-only into the API container for trusted financial receipts.
SIQ_HERMES_HOST_HOME=/var/lib/siq-research-engine/runtime/hermes/home
SIQ_IC_TASK_LEASE_SECONDS=120
SIQ_IC_TASK_HEARTBEAT_SECONDS=30
SIQ_IC_TASK_LEASE_BACKEND=postgres
SIQ_MINERU_VENV=/opt/siq-research-engine/runtimes/mineru-native

SIQ_BACKEND_PORT=18081
SIQ_FRONTEND_PORT=15173
SIQ_PDF2MD_PORT=15000
SIQ_PRIMARY_MARKET_PROSPECTUS_MAX_FILE_BYTES=104857600
SIQ_PRIMARY_MARKET_PROSPECTUS_MAX_BATCH_BYTES=104857600
SIQ_PRIMARY_MARKET_AUTO_ACTIVATE_QUALITY_PASS=1
SIQ_PRIMARY_MARKET_RECONCILE_ON_STARTUP=1
SIQ_PRIMARY_MARKET_RECONCILE_STARTUP_LIMIT=50
SIQ_PRIMARY_MARKET_RECONCILE_INTERVAL_SECONDS=0
SIQ_PDF_QUEUE_GLOBAL_TASK_LIMIT=32
SIQ_PDF_QUEUE_OWNER_TASK_LIMIT=8
