# Production deployment template for SIQ Research Engine.
# Copy to a secret-managed environment, replace every placeholder, and keep real values out of Git.

SIQ_PROJECT_ROOT=/opt/siq-research-engine
SIQ_DATA_ROOT=/var/lib/siq-research-engine
SIQ_RUNTIME_ROOT=/var/lib/siq-research-engine
SIQ_ARTIFACTS_ROOT=/var/lib/siq-research-engine/artifacts
SIQ_DATASETS_ROOT=/opt/siq-research-engine/datasets

SIQ_AUTH_SECRET_KEY=replace-with-secret-manager-value
SIQ_AUTH_COOKIE_MODE=1
SIQ_AUTH_COOKIE_SECURE=1
SIQ_AUTH_COOKIE_SAMESITE=lax
SIQ_SOURCE_TOKEN_SECRET=replace-with-secret-manager-value
SIQ_SOURCE_ACCEPT_LEGACY_AUTH_SECRET=0
SIQ_ALLOW_REGISTRATION=0
SIQ_DEMO_MODE=0
SIQ_INITIAL_ADMIN_PASSWORD=replace-with-secret-manager-value
SIQ_CREATE_DEMO_USERS=0

SIQ_APP_DATABASE_URL=postgresql+psycopg://siq:replace-with-db-password@postgres.example.internal:5432/siq_app
REDIS_URL=redis://redis.example.internal:6379/0

SIQ_AGENT_MEMORY_ENABLED=true
SIQ_AGENT_MEMORY_WRITE_ENABLED=true
SIQ_AGENT_MEMORY_RETRIEVAL_ENABLED=true
SIQ_AGENT_MEMORY_VECTOR_BACKEND=milvus
SIQ_AGENT_MEMORY_PGVECTOR_ENABLED=false
SIQ_AGENT_MEMORY_EXTRACTION_ENABLED=true
SIQ_AGENT_MEMORY_SCHEMA=agent_memory
SIQ_AGENT_MEMORY_MILVUS_COLLECTION=siq_agent_memory
SIQ_AGENT_MEMORY_EMBEDDING_DIM=1024
SIQ_AGENT_MEMORY_EMBEDDING_BASE_URL=https://embedding.example.internal
SIQ_AGENT_MEMORY_EMBEDDING_MODEL=Qwen3-VL-Embedding-2B
SIQ_AGENT_MEMORY_RERANK_ENABLED=true
SIQ_RERANK_BASE_URL=https://reranker.example.internal
SIQ_RERANK_MODEL=Qwen3-VL-Reranker-2B
SIQ_AGENT_MEMORY_DEFAULT_VISIBILITY=user_private
SIQ_AGENT_MEMORY_PRIMARY_MARKET_VISIBILITY=project_shared
SIQ_AGENT_MEMORY_MAX_ITEMS=8
SIQ_AGENT_MEMORY_FULL_RECALL_MAX_ITEMS=25
SIQ_AGENT_MEMORY_MAX_TOKENS=1800
SIQ_AGENT_MEMORY_MIN_SCORE=0.72
SIQ_AGENT_MEMORY_RETRIEVAL_BUDGET_MS=1200
SIQ_AGENT_MEMORY_RERANK_TIMEOUT=1.0
SIQ_AGENT_MEMORY_MIN_QUERY_CHARS=4
SIQ_AGENT_MEMORY_TIME_DECAY_ENABLED=true
SIQ_AGENT_MEMORY_TIME_DECAY_HALF_LIFE_DAYS=30
SIQ_AGENT_MEMORY_TIME_DECAY_FLOOR=0.35
SIQ_MILVUS_HOST=milvus.example.internal
SIQ_MILVUS_PORT=19530

SIQ_WIKI_ROOT=/var/lib/siq-research-engine/wiki
SIQ_ASSISTANT_WIKI_ROOT=/var/lib/siq-research-engine/wiki
SIQ_DEFAULT_SOURCE_TYPE=wiki_metrics
SIQ_ASSISTANT_DEFAULT_SOURCE_TYPE=wiki_metrics

SIQ_BACKEND_ROOT=/opt/siq-research-engine/apps/api
SIQ_FRONTEND_ROOT=/opt/siq-research-engine/apps/web
SIQ_PDF2MD_ROOT=/opt/siq-research-engine/apps/pdf-parser
SIQ_PDF2MD_DATA_DIR=/var/lib/siq-research-engine/pdf-parser
SIQ_DOCUMENT_PARSER_ROOT=/opt/siq-research-engine/apps/document-parser
SIQ_DOCUMENT_PARSE_DATA_DIR=/var/lib/siq-research-engine/document-parser
SIQ_REPORT_FINDER_ROOT=/opt/siq-research-engine/services/market-report-finder
SIQ_MARKET_REPORT_FINDER_ROOT=/opt/siq-research-engine/services/market-report-finder
SIQ_MARKET_REPORT_RULES_ROOT=/opt/siq-research-engine/services/market-report-rules
SIQ_REPORT_DOWNLOADS_ROOT=/var/lib/siq-research-engine/market-report-finder/downloads
SIQ_MARKET_REPORT_DOWNLOADS_ROOT=/var/lib/siq-research-engine/market-report-finder/downloads

SIQ_DB_ROOT=/opt/siq-research-engine/db
SIQ_DOCUMENT_PGDATABASE=siq_document_parser
SIQ_US_PGDATABASE=siq_us
SIQ_HK_PGDATABASE=siq_hk
SIQ_JP_PGDATABASE=siq_jp
SIQ_KR_PGDATABASE=siq_kr
SIQ_EU_PGDATABASE=siq_eu
SIQ_HERMES_HOME=/var/lib/siq-research-engine/hermes/home
SIQ_HERMES_PROFILES_ROOT=/var/lib/siq-research-engine/hermes/home/profiles
SIQ_MINERU_VENV=/opt/siq-research-engine/runtimes/mineru-native

SIQ_BACKEND_PORT=18081
SIQ_FRONTEND_PORT=15173
SIQ_PDF2MD_PORT=15000
SIQ_DOCUMENT_PARSER_PORT=15010
SIQ_REPORT_FINDER_PORT=18000
SIQ_MARKET_REPORT_FINDER_PORT=18010
SIQ_MARKET_REPORT_RULES_PORT=18020
SIQ_BACKEND_URL=https://api.example.com
SIQ_REPORT_FINDER_URL=https://report-finder.example.com
SIQ_MARKET_REPORT_FINDER_URL=https://market-report-finder.example.com
SIQ_MARKET_REPORT_RULES_URL=https://market-report-rules.example.com
SIQ_PDFAPI_URL=https://pdf-parser.example.com
SIQ_REPORT_FINDER_BASE=https://report-finder.example.com
SIQ_MARKET_REPORT_FINDER_BASE=https://market-report-finder.example.com
SIQ_MARKET_REPORT_RULES_BASE=https://market-report-rules.example.com
SIQ_PDF2MD_API_BASE=https://pdf-parser.example.com
SIQ_DOCUMENT_PARSER_API_BASE=https://document-parser.example.com
SIQ_REPORT_FINDER_HEALTH_URL=https://report-finder.example.com/health
SIQ_MARKET_REPORT_FINDER_HEALTH_URL=https://market-report-finder.example.com/health
SIQ_MARKET_REPORT_RULES_HEALTH_URL=https://market-report-rules.example.com/healthz
SIQ_PDF2MD_HEALTH_URL=https://pdf-parser.example.com/api/health
SIQ_DOCUMENT_PARSER_HEALTH_URL=https://document-parser.example.com/api/health
SIQ_PUBLIC_ORIGIN=https://app.example.com

SIQ_START_HERMES_GATEWAYS=1
SIQ_START_MARKET_REPORT_FINDER=0
SIQ_START_MARKET_REPORT_RULES=0
SIQ_START_VECTOR_INGEST=0
SIQ_MILVUS_COLLECTION=ic_collaboration_shared

SEC_USER_AGENT=SIQ Research Engine ops@example.com
DART_API_KEY=replace-with-secret-manager-value
EDINET_API_KEY=replace-with-secret-manager-value
PDF2MD_ACCESS_TOKEN=replace-with-secret-manager-value
MINERU_API_URL=http://mineru.example.internal:8003
VLM_API_URL=http://vlm.example.internal:8002
