SIQ_BACKEND_URL=https://api.example.com
SIQ_REPORT_FINDER_URL=https://report-finder.example.com
SIQ_MARKET_REPORT_FINDER_URL=https://market-report-finder.example.com
SIQ_MARKET_REPORT_RULES_URL=https://market-report-rules.example.com
SIQ_REPORT_FINDER_BASE=https://report-finder.example.com
SIQ_MARKET_REPORT_FINDER_BASE=https://market-report-finder.example.com
SIQ_MARKET_REPORT_RULES_BASE=https://market-report-rules.example.com
SIQ_PDF2MD_API_BASE=https://pdf-parser.example.com
