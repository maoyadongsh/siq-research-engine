# Both product flags must be enabled before start_meeting_speech.sh starts a process.
SIQ_MEETINGS_ENABLED=0
SIQ_MEETING_REALTIME_ASR_ENABLED=0

SIQ_MEETING_SPEECH_DEPLOYMENT_PROFILE=local
SIQ_MEETING_SPEECH_HOST=127.0.0.1
SIQ_MEETING_SPEECH_PORT=8901
SIQ_MEETING_SPEECH_INTERNAL_SERVICE_TOKEN=

# Production uses funasr. mock is test/development only and requires the explicit opt-in below.
SIQ_MEETING_SPEECH_ADAPTER=funasr
SIQ_MEETING_SPEECH_ALLOW_DEGRADED_MOCK=0
SIQ_MEETING_SPEECH_FUNASR_SOURCE_ROOT=/home/maoyd/services/FunASR
SIQ_MEETING_SPEECH_PYTHON_BIN=/home/maoyd/miniconda3/envs/funasr-vllm/bin/python
SIQ_MEETING_SPEECH_DEVICE=cpu
SIQ_MEETING_SPEECH_ONLINE_MODEL=iic/speech_paraformer_asr_nat-zh-cn-16k-common-vocab8404-online
SIQ_MEETING_SPEECH_FINAL_MODEL=paraformer-zh
SIQ_MEETING_SPEECH_VAD_MODEL=fsmn-vad
SIQ_MEETING_SPEECH_PUNCTUATION_MODEL=ct-punc

# Optional isolation mode: use existing 8899 only for bounded sentence-final review.
# Realtime partial and VAD remain in this independent process.
SIQ_MEETING_SPEECH_FINALIZER=local
SIQ_MEETING_SPEECH_HTTP_FINALIZER_URL=http://127.0.0.1:8899/asr
SIQ_MEETING_SPEECH_HTTP_FINALIZER_HEALTH_URL=http://127.0.0.1:8899/openapi.json
SIQ_MEETING_SPEECH_HTTP_FINALIZER_TIMEOUT_SECONDS=15
SIQ_MEETING_SPEECH_HTTP_FINALIZER_MAX_CONCURRENCY=1

# Anonymous in-meeting tracks. The embedding endpoint is independently gated and off by default.
SIQ_MEETING_SPEECH_SPEAKER_ADAPTER=none
SIQ_MEETING_SPEECH_SPEAKER_MODEL=iic/speech_eres2netv2_sv_zh-cn_16k-common
SIQ_MEETING_SPEECH_SPEAKER_CLUSTER_THRESHOLD=0.72
SIQ_MEETING_SPEECH_SPEAKER_CLUSTER_UPDATE_THRESHOLD=0.82
SIQ_MEETING_SPEECH_SPEAKER_CLUSTER_MIN_MARGIN=0.04
SIQ_MEETING_SPEECH_SPEAKER_CANDIDATE_THRESHOLD=0.78
SIQ_MEETING_SPEECH_SPEAKER_CANDIDATE_CONFIRMATIONS=2
SIQ_MEETING_SPEECH_SPEAKER_CANDIDATE_MAX_GAP_MS=30000
SIQ_MEETING_SPEECH_SPEAKER_MAX_TRACKS=16
SIQ_MEETING_SPEECH_SPEAKER_MIN_SEGMENT_MS=1000
SIQ_MEETING_SPEECH_SPEAKER_NEW_TRACK_MIN_SEGMENT_MS=1500
SIQ_MEETING_SPEECH_SPEAKER_MAX_PROTOTYPES=8
SIQ_MEETING_SPEECH_SPEAKER_MIN_RMS=0.005
SIQ_MEETING_SPEECH_SPEAKER_MAX_CLIPPING_RATIO=0.2
SIQ_MEETING_SPEECH_EMBEDDING_ENDPOINT_ENABLED=0
SIQ_MEETING_SPEECH_EMBEDDING_MIN_SECONDS=1
SIQ_MEETING_SPEECH_EMBEDDING_MAX_SECONDS=15
SIQ_MEETING_SPEECH_EMBEDDING_MAX_CONCURRENCY=1

SIQ_MEETING_SPEECH_MAX_ACTIVE_SESSIONS=4
SIQ_MEETING_SPEECH_MAX_RESIDENT_SESSIONS=8
SIQ_MEETING_SPEECH_RESUME_TTL_SECONDS=60
SIQ_MEETING_SPEECH_MAX_FRAME_BYTES=32000
SIQ_MEETING_SPEECH_MAX_PENDING_FRAMES=16
SIQ_MEETING_SPEECH_MAX_PENDING_BYTES=512000
SIQ_MEETING_SPEECH_MAX_GAP_FRAMES=64
SIQ_MEETING_SPEECH_MAX_SEGMENT_SECONDS=30
SIQ_MEETING_SPEECH_MAX_SESSION_SECONDS=14400
SIQ_MEETING_SPEECH_INFERENCE_TIMEOUT_SECONDS=15
